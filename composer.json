{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "license": "AGPL-3.0",
    "type": "project",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.0",
        "endroid/qr-code": "^6.0",
        "google/apiclient": "1.0.*@beta",
        "guzzlehttp/guzzle": "^7.0.1",
        "imagine/imagine": "1.5.0",
        "laravel/framework": "^12.0",
        "laravel/helpers": "^1.7",
        "laravel/horizon": "^5.45",
        "league/flysystem-aws-s3-v3": "^3.0",
        "openai-php/laravel": "^0.18.0",
        "openspout/openspout": "^4.28",
        "pgvector/pgvector": "^0.2.1",
        "phpoffice/phpspreadsheet": "^3.9",
        "predis/predis": "^2.0",
        "rcrowe/twigbridge": "^0.14.3",
        "twig/markdown-extra": "^3.20",
        "twig/twig": "~3.9"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "barryvdh/laravel-ide-helper": "^3.5",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.2",
        "laravel/tinker": "^2.10.1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SzentirasHu\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "classmap": [
        ],
        "psr-4": {
            "SzentirasHu\\Test\\": "tests/feature",
            "SzentirasHu\\Test\\Smoke\\": "tests/smoke",
            "SzentirasHu\\Test\\Common\\": "tests/common"        }

    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php artisan clear-compiled"
        ],
        "pre-update-cmd": [
            "php artisan clear-compiled"
        ],
        "post-update-cmd": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models -W"
        ],
        "post-create-project-cmd": [
            "php artisan key:generate --ansi"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]    
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true,
            "php-http/discovery": true
        }
    },
    "prefer-stable": true

}
