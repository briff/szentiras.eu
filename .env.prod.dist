APP_URL=https://szentiras.eu
APP_DOMAIN=szentiras.eu
ASSET_URL=https://szentiras.eu

APP_ENV=production
APP_DEBUG=false
# Generate with php artisan key:generate or with php artisan key:generate --show  (and set as application secret)
APP_KEY=
APP_UNREGISTERED_SEARCH_LIMIT=10

DB_TYPE=pgsql
DB_CONNECTION=bible
DB_HOST=database
DB_DATABASE=bible
DB_USERNAME=
DB_PASSWORD=
DB_PREFIX=kar_
DB_PORT=5432

POSTGRES_USER=${DB_USERNAME}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=${DB_DATABASE}

CACHE_DRIVER=memcached
SESSION_DRIVER=file
QUEUE_DRIVER=redis
REDIS_HOST=redis

ENABLED_TRANSLATIONS=1,4,5,7,9
AUDIO_DIRECTORY=hang
LOG_LEVEL=warning
SPHINX_HOST=sphinx
SPHINX_PORT=9306

GOOGLE_API_KEY=seeInGoogleDeveloperConsole

TEXT_SOURCE_BD=s3
TEXT_SOURCE_KG=s3
TEXT_SOURCE_KNB=s3
TEXT_SOURCE_KAL=s3
TEXT_SOURCE_UF=s3
TEXT_SOURCE_RUF=s3
TEXT_SOURCE_SZIT=s3

TRANSLATION_ABBREV_REGEX=KNB|SZIT|UF|KG|BD|RUF|STL|KAL|knb|szit|uf|kg|bd|ruf|stl|kal

OPENAI_API_KEY=
OPENAI_ORGANIZATION=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=

CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Cloudflare cache purge (run `php artisan cdn:purge` after text updates).
# API token needs the "Zone.Cache Purge" permission for the zone.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Shared (CDN) caching of anonymous text pages.
PUBLIC_PAGE_CACHE_ENABLED=true
PUBLIC_PAGE_BROWSER_MAX_AGE=300
PUBLIC_PAGE_CDN_MAX_AGE=2592000

AI_COMMENTARY_ALL_USERS_ALLOWED=false
AI_COMMENTARY_STORE=true
AI_COMMENTARY_API_KEY=
AI_COMMENTARY_ORGANIZATION=
AI_COMMENTARY_MODEL=gpt-5.2

PIXABAY_API_KEY=