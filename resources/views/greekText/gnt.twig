{% extends "layout" %}

{% if book %}
    {% set pageTitle = book.name ~ (currentChapter is not null ? ' ' ~ currentChapter ~ '. fejezet' : '') ~ ' – Görög Újszövetségi Szentírás' %}
{% else %}
    {% set pageTitle = 'Görög Újszövetségi Szentírás' %}
{% endif %}

{% block meta %}
    {% set gntPath = '/GNT' ~ (book ? '/' ~ book.abbrev ~ (currentChapter is not null ? currentChapter : '') : '') %}
    <link rel="canonical" href="{{ url(gntPath) }}" />
    <meta property="og:url" content="{{ url(gntPath) }}">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ teaser }}">
    <meta property="og:image" content="{{ asset('img/biblia.jpg') }}">
{% endblock %}

{% block content %}

    {% set compareQuery = (compareTranslation is defined and compareTranslation) ? '?compare=' ~ compareTranslation.abbrev : '' %}

    <h2>Görög Újszövetségi Szentírás</h2>

    {% if showLanding %}
    <div class="card mb-2">
        <div class="card-body">
            <p class="lead">
                Teljes újszövetségi görög Szentírás és görög–magyar újszövetségi szószedet, amelyet mesterséges intelligencia eszközök
                segítségével készítettünk.
            </p>
            <p>
                A görög szentírás alapszövege az <strong>OpenGNT</strong>, a legkorszerűbb, szabadon
                felhasználható újszövetségi szövegforrás.
            </p>
            <p class="mb-1">
                <i class="bi bi-info-circle"></i>
                A szöveget olvasva a <strong>versszámokra kattintva</strong> megjelennek az adott vershez tartozó
                magyar fordítások, valamint a görög szavak szómagyarázatai.
            </p>
        </div>
    </div>

    <div class="card mb-2">
        <div class="card-body">
            <h5 class="card-title"><i class="bi bi-book"></i> Olvasás könyv szerint</h5>
            <div class="d-flex flex-wrap gap-2">
                {{
                    books
                        |map(b => "<a href=\"/GNT/#{b.abbrev}\" class=\"btn btn-sm btn-outline-primary\" role=\"button\">#{b.abbrev}</a>")
                        |join("")|raw
                }}
            </div>
        </div>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-search"></i> Görög kereső</h5>
                    <p class="card-text">
                        Keresés görög szó / magyar jelentés és görög szövegrészlet alapján, latin átírással.
                    </p>
                    <a href="/kereses?greek=1" class="btn btn-outline-primary btn-sm">Görög kereső megnyitása</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-journal-text"></i> Görög szótár</h5>
                    <p class="card-text">
                        Az összes Strong szó betűrendben: jelentés, magyarázat és előfordulások.
                    </p>
                    <a href="{{ route('greekDictionary.index') }}" class="btn btn-outline-primary btn-sm">Szótár megnyitása</a>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# Translation switcher #}
    {% if translationLinks is defined and not showLanding %}
    <div class="card mb-2">
        <div class="card-body text-center">
            <div class="d-flex flex-wrap justify-content-center gap-1">
                {% for otherTranslation in translationLinks %}
                    {% if otherTranslation.abbrev != 'GNT' %}
                        {% if otherTranslation.enabled %}
                            <a class="btn btn-sm btn-outline-primary" role="button" href="{{ otherTranslation.link starts with '/' ? otherTranslation.link : '/' ~ otherTranslation.link }}">{{ otherTranslation.abbrev }}</a>
                        {% else %}
                            <a class="btn btn-sm btn-outline-primary disabled"  role="button" title="A hivatkozás {{ otherTranslation.abbrev }} fordításban nem elérhető.">{{ otherTranslation.abbrev }}</a>
                        {% endif %}
                    {% else %}
                        <a href="#" class="btn btn-sm btn-secondary disabled"  >{{ otherTranslation.abbrev }}</a>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="d-flex flex-wrap justify-content-center gap-1 mt-2">
                <a href="/kereses?greek=1" class="btn btn-sm btn-outline-secondary" role="button"><i class="bi bi-search"></i> Görög kereső</a>
                <a href="{{ route('greekDictionary.index') }}" class="btn btn-sm btn-outline-secondary" role="button"><i class="bi bi-journal-text"></i> Görög szótár</a>
            </div>
        </div>
    </div>
    {% endif %}

    {% if not showLanding %}
    <div class="card mb-2">
    <div class="card-body text-center">
        {{
            books
                |map(b => (b == book) ? "<b>#{b.abbrev}</b>" :  "<a href=\"/GNT/#{b.abbrev}\" class=\"minilink\">#{b.abbrev}</a>")
                |join(" ◦ ")|raw
        }}
    </div>

</div>

    {% if currentChapter is not null %}
    <div class="card mb-2">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-2">
                {% if previousChapter is not null %}
                    <a class="btn btn-sm btn-outline-primary" role="button" href="/GNT/{{ book.abbrev }}{{ previousChapter }}{{ compareQuery }}">
                        <i class="bi bi-chevron-left"></i> Előző
                    </a>
                {% else %}
                    <span class="btn btn-sm btn-outline-primary disabled"><i class="bi bi-chevron-left"></i> Előző</span>
                {% endif %}
                <span class="fw-bold">{{ book.abbrev }} {{ currentChapter }}</span>
                {% if nextChapter is not null %}
                    <a class="btn btn-sm btn-outline-primary" role="button" href="/GNT/{{ book.abbrev }}{{ nextChapter }}{{ compareQuery }}">
                        Következő <i class="bi bi-chevron-right"></i>
                    </a>
                {% else %}
                    <span class="btn btn-sm btn-outline-primary disabled">Következő <i class="bi bi-chevron-right"></i></span>
                {% endif %}
            </div>
            <div class="d-flex flex-wrap gap-1 justify-content-center">
                {% for ch in chapters %}
                    {% if ch == currentChapter %}
                        <span class="btn btn-sm btn-primary disabled">{{ ch }}</span>
                    {% else %}
                        <a class="btn btn-sm btn-outline-secondary" role="button" href="/GNT/{{ book.abbrev }}{{ ch }}{{ compareQuery }}">{{ ch }}</a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}
    {% endif %}

    {% if compareTranslation is defined and compareTranslation and compareVerseContainers %}
        {% set rightMap = {} %}
        {% for container in compareVerseContainers %}
            {% for cv in container.parsedVerses %}
                {% set rightMap = rightMap|merge({ (cv.chapter ~ ':' ~ cv.numv): cv }) %}
            {% endfor %}
        {% endfor %}
        {{ include('textDisplay.compareVerseGrid', {
            'leftList': greekVerses,
            'leftType': 'greek',
            'rightMap': rightMap,
            'rightType': 'verse',
            'leftLabel': 'GNT',
            'rightLabel': compareTranslation.name,
            'compareTranslation': compareTranslation
        }) }}
    {% else %}
    {% set displayedChapter = null %}
    <div class="parsedVerses greek">
        {% for greekVerse in greekVerses %}
            {% if displayedChapter != greekVerse.chapter and greekVerse.verse == 1 %}
                <span class="numchapter">{{ greekVerse.chapter }}</span>
                {% set displayedChapter = greekVerse.chapter %}
            {% endif %}
                <span class="numv hidden"><sup>{{ greekVerse.verse }}</sup></span>
                {% if book %}
                <a class="numvai" data-bs-placement="auto" tabindex="0" data-bs-custom-class="ai-tool-popover" data-link="{{ translation.abbrev }}/{{ book.abbrev }}{{ greekVerse.chapter }},{{ greekVerse.verse }}">
                    <span class="numvai">{{ greekVerse.verse }}&nbsp;</span>
                </a>
                {% endif %}
                <span class="verse-text">{% include 'greekText.clickableGreekText' with {'words': greekVerse.annotatedWords} %}</span>
        {% endfor %}
    </div>
    {% endif %}

    {% include 'greekText.greekWordOffcanvas' %}

    {% if currentChapter is not null and (previousChapter is not null or nextChapter is not null) %}
    <div class="d-flex align-items-center justify-content-between mt-3">
        {% if previousChapter is not null %}
            <a class="btn btn-sm btn-outline-primary" role="button" href="/GNT/{{ book.abbrev }}{{ previousChapter }}{{ compareQuery }}">
                <i class="bi bi-chevron-left"></i> {{ book.abbrev }} {{ previousChapter }}
            </a>
        {% else %}
            <span></span>
        {% endif %}
        {% if nextChapter is not null %}
            <a class="btn btn-sm btn-outline-primary" role="button" href="/GNT/{{ book.abbrev }}{{ nextChapter }}{{ compareQuery }}">
                {{ book.abbrev }} {{ nextChapter }} <i class="bi bi-chevron-right"></i>
            </a>
        {% else %}
            <span></span>
        {% endif %}
    </div>
    {% endif %}

{% endblock %}

{% block extramenu %}
    <div class="card">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm active" id="toggleNumv" title="Versszámozás" style="background-color: #0d6efd; color: white;">
                    <i class="bi-123"></i>
                </button>
                <button type="button" class="btn btn-sm active" id="toggleXrefs" title="Hivatkozások" style="background-color: #0d6efd; color: white;">
                    <i class="bi-link-45deg"></i>
                </button>
                <button type="button" class="btn btn-sm active" id="toggleHeadings" title="Címsorok" style="background-color: #0d6efd; color: white;">
                    <i class="bi-card-heading"></i>
                </button>
                <button type="button" class="btn btn-sm inactive" id="toggleAiTools" title="Segédeszközök" style="background-color: transparent; color: #0d6efd; border: 1px solid #0d6efd;">
                    <i class="bi-tools"></i>
                </button>
                {% if book and currentChapter is not null %}
                    {% set gntChapterPath = '/GNT/' ~ book.abbrev ~ currentChapter %}
                    <div class="btn-group" role="group">
                        <button type="button" class="btn btn-sm {% if compareTranslation %}active{% else %}inactive{% endif %}" data-bs-toggle="dropdown" title="Fordítás párhuzamos olvasása" style="{% if compareTranslation %}background-color: #0d6efd; color: white;{% else %}background-color: transparent; color: #0d6efd; border: 1px solid #0d6efd;{% endif %}">
                            <i class="bi-columns-gap"></i>
                        </button>
                        <ul class="dropdown-menu">
                            {% if compareTranslation %}
                                <li><span class="dropdown-item-text"><strong>{{ compareTranslation.name }}</strong></span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ gntChapterPath }}">
                                    <i class="bi-x"></i> Összehasonlítás bezárása
                                </a></li>
                            {% else %}
                                {% for otherTranslation in translationLinks %}
                                    {% if otherTranslation.abbrev != 'GNT' and otherTranslation.enabled %}
                                        <li><a class="dropdown-item" href="{{ gntChapterPath }}?compare={{ otherTranslation.abbrev }}">
                                            {{ otherTranslation.abbrev }}
                                        </a></li>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                        </ul>
                    </div>
                {% endif %}
                {% if not mediaEnabled %}
                    <a class="btn btn-sm {{ hasMedia ? '' : 'd-none' }}" id="mediaButton" href="{{ url('/' ~ canonicalUrl ~ '?media' ~ (fullContext ? '&fullContext' : '')) }}" title="Illusztrációk megjelenítése">
                        <i class="bi-images"></i>
                    </a>
                {% endif %}
                {% if mediaEnabled %}
                    <a class="btn btn-sm {{ hasMedia ? '' : 'd-none' }}" id="mediaButton" href="{{ url('/' ~ canonicalUrl ~ (fullContext ? '?fullContext' : '')) }}" title="Illusztrációk elrejtése">
                        <i class="bi-images"></i>
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% set js=['pages/verses'] %}