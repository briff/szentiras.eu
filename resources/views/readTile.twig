<div class="card h-100 border-0" style="background-color: #f8f7f4;">
    <div class="card-body text-center">
        <div class="d-flex align-items-center justify-content-center mb-2">
            <i class="bi-book display-5 me-3" style="color: #8b8fa8;"></i>
            <h5 class="card-title mb-0" style="color: #4a5568;">Olvasás</h5>
        </div>
        <p class="card-text mb-2 d-none d-md-block" style="color: #718096;">Válassz könyvet/fejezetet/verset</p>
        
        <div class="mt-2 text-start">
            <div class="row g-2 mb-2">
                <div class="col-12">
                    <div class="input-group">
                        <input type="text" class="form-control" id="referenceInput" placeholder="pl. 1Kor13,1-13" style="border-color: #d4cfc9; background-color: #fdfcfb;">
                        <button class="btn" id="goToReferenceButton" type="button" disabled style="color: #8b8fa8; border-color: #d4cfc9; background-color: #ede9e4;">
                            <i class="bi-arrow-right"></i> Ugrás
                        </button>
                    </div>
                </div>
            </div>

            {% include 'quickChapterSelector' %}

            {% if todayDailyReading is not null %}
            <div class="mt-2">
                <a href="/{{ todayDailyReading.combinedRefString }}" class="btn btn-sm w-100" style="color: #7a6b4e; border-color: #c4a96a; background-color: #faf5ec;">
                    <i class="bi-sun me-1"></i> Mai olvasmányok
                    {% if todayDailyReading.celebration_name is not null %}
                    <span class="d-block small text-muted" style="font-size: 0.75em;">{{ todayDailyReading.celebration_name }}</span>
                    {% endif %}
                </a>
            </div>
            {% endif %}

        </div>
    </div>
</div>