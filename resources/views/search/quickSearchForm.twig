
{% set extraClass = extraClass|default('') %}
<div class="card {{ extraClass }}" id="accordion">
    <div class="card-header d-none d-md-block">
        Keresés a Bibliában
    </div>
    <div class="card-body">
        <form id="quickSearchForm" role="form" method="post" class="form-inline"
                action="/kereses/quicksearch" id="quickSearchForm">
            <div class="form-group">
                <div class="input-group">
                    <input id="quickSearch" autocomplete="off" type="text" class="form-control" name="textToSearch" value="{{ form.textToSearch }}" placeholder="Gyorskeresés">
                    <input id="grouping" type="hidden" class="form-control" name="grouping" value="verse">
                    {{ csrf_field() }}
                    <div class="input-group-append position-relative">
                        <a href="javascript:void(0)" class="quickSearchButton btn btn-default btn-primary">
                            <span id="quickSearchHitsButtonContent"><i class="bi-search"></i></span>
                            <span id="quickSearchResultsBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none z-3">
                                <span id="quickSearchResultsCount">0</span>
                                <span class="visually-hidden">találat</span>
                            </span>
                        </a>
                    </div>
                    <div class="input-group-append z-0">
                        <a href="javascript:void(0)" title="Részletes keresés" class="quickSearchButton btn-secondary {{ fullQuickSearch ? 'd-none' : 'd-md-none d-lg-none' }} btn btn-default"><i class="bi-gear"></i></a></span>
                    </div>
                    <div class="input-group-append">
                        <a href="/ai-search" title="MI keresés" class="btn-secondary {{ fullQuickSearch ? 'd-none' : 'd-md-none d-lg-none' }} btn btn-default"><i class="bi-robot"></i></a></span>                            
                    </div>

                </div>
            </div>
        </form>
        <div class="d-flex flex-wrap">
        <div class="{{ fullQuickSearch ? '' : 'd-none d-md-block' }} text-center mt-2 flex-fill">
            <a href="javascript:void(0)" role="button" class="quickSearchButton btn btn-secondary btn-default"><i class="bi-gear"></i> Részletes keresés</a>
        </div>
        <div class="{{ fullQuickSearch ? '' : 'd-none d-md-block' }} text-center mt-2 flex-fill">
            <a href="/ai-search" role="button" class="btn btn-secondary btn-default"><i class="bi-robot"></i> MI keresés</a>
        </div>
    </div>
    </div>
</div>
