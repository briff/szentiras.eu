<div class="card h-100">
    <div class="card-body text-center">
        <i class="bi-search display-4 text-success mb-3"></i>
        <h5 class="card-title">Keresés</h5>
        <p class="card-text text-muted mb-3">Keress szavakat, kifejezéseket a teljes Bibliában</p>
        
        <div class="mt-4 text-start">
            <form id="quickSearchForm" role="form" method="post" class="mb-3"
                    action="/kereses/quicksearch">
                <div class="input-group">
                    <input id="quickSearch" autocomplete="off" type="text" class="form-control" name="textToSearch" value="{{ form.textToSearch|default('') }}" placeholder="Írd be a keresendő szót...">
                    <input id="grouping" type="hidden" class="form-control" name="grouping" value="verse">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-primary">
                        <i class="bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="accordion" id="searchOptionsAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSearchOptions" aria-expanded="false" aria-controls="collapseSearchOptions">
                            <i class="bi-gear me-2"></i> Részletes keresési beállítások
                        </button>
                    </h2>
                    <div id="collapseSearchOptions" class="accordion-collapse collapse" data-bs-parent="#searchOptionsAccordion">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <label class="form-label">Keresés típusa</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="searchType" id="searchTypeQuick" autocomplete="off" checked>
                                    <label class="btn btn-outline-primary" for="searchTypeQuick">Gyors</label>
                                    
                                    <input type="radio" class="btn-check" name="searchType" id="searchTypeAdvanced" autocomplete="off">
                                    <label class="btn btn-outline-primary" for="searchTypeAdvanced">Részletes</label>
                                    
                                    <input type="radio" class="btn-check" name="searchType" id="searchTypeGreek" autocomplete="off">
                                    <label class="btn btn-outline-primary" for="searchTypeGreek">Görög</label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Testamentum</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="testament" id="testamentAll" autocomplete="off" checked>
                                    <label class="btn btn-outline-secondary" for="testamentAll">Mind</label>
                                    
                                    <input type="radio" class="btn-check" name="testament" id="testamentOld" autocomplete="off">
                                    <label class="btn btn-outline-secondary" for="testamentOld">Ószövetség</label>
                                    
                                    <input type="radio" class="btn-check" name="testament" id="testamentNew" autocomplete="off">
                                    <label class="btn btn-outline-secondary" for="testamentNew">Újszövetség</label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Fordítás</label>
                                <select class="form-select" id="translationSelect">
                                    <option value="all" selected>Összes fordítás</option>
                                    <option value="katolikus">Katolikus fordítások</option>
                                    <option value="protestans">Protestáns fordítások</option>
                                    <!-- More options will be populated dynamically -->
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <div class="d-grid gap-2">
                    <a href="/kereses" class="btn btn-outline-primary">
                        <i class="bi-list-ul me-1"></i> Teljes keresési oldal
                    </a>
                    <a href="/ai-search" class="btn btn-outline-success">
                        <i class="bi-robot me-1"></i> MI keresés
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <div class="text-center">
                    <small class="text-muted">
                        <i class="bi-info-circle me-1"></i>
                        Tipp: Használj idézőjeleket pontos kifejezés kereséséhez
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>