{% set verification_config = {
    'none': {icon: 'bi-exclamation-triangle', color: 'text-white bg-danger', label: 'MI-kommentár, nincs ellenőrizve, lehet pontatlan, téves'},
    'sanity': {icon: 'bi-exclamation-circle', color: 'text-dark bg-warning', label: 'MI-kommentár, értelmi ellenőrzésen átesett, teológiailag lehet téves'},
    'theology': {icon: 'bi-check-circle', color: 'text-white bg-success', label: 'MI-kommentár, teológiai ellenőrzésen átesett, nagy valószínűséggel pontos'}
} %}

{% for verseContainer in verseContainers %}
    <div>
        {% include 'textDisplay.breadcrumb' with {'book': verseContainer.book, 'bookRef': verseContainer.bookRef } %}
        {% set containerPlaces = parsedPlaces[loop.index0] ?? [] %}
        {% if containerPlaces is not empty %}
            <div class="mt-3 mb-3">
                <button class="btn btn-sm btn-outline-success ai-tool-element"
                        data-bs-toggle="modal"
                        data-bs-target="#placeModal"
                        data-place-ids="{{ containerPlaces|map(arrow => arrow.place_id)|join(',') }}"
                        title="Helyek megtekintése">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span class="ms-2">Helyek megtekintése</span>
                </button>
            </div>
        {% endif %}
    </div>
        <div class="mb-2">
         {{ include('textDisplay.parsedVerseContainer', { 'verseContainer' : verseContainer, 'translation' : translation, 'verseToPlaces': verseToPlaces}) }}
            {# Commentary section #}
            {% set containerCommentaries = parsedCommentaries[loop.index0] ?? [] %}
            {% set containerReference = verseContainer.bookRef.toString() %}

            {# Separate exact and non-exact commentaries, and pending/processing ones #}
            {% set exactCommentaries = containerCommentaries|filter(c => c.exact and c.status == 'completed') %}
            {% set relatedCommentaries = containerCommentaries|filter(c => not c.exact and c.status == 'completed') %}
            {% set pendingCommentaries = containerCommentaries|filter(c => c.status == 'pending' or c.status == 'processing') %}

            <div class="commentary-container" data-reference="{{ containerReference }}" data-translation="{{ translation.abbrev }}" data-container-index="{{ loop.index0 }}">
                {# Commentary section - no longer in tabs #}
                {% if containerCommentaries is not empty %}
                    <div class="commentaries mt-2 mb-2 parsedVerses">
                        <details class="overflow-hidden">
                            <summary class="h6 cursor-pointer flex items-center bg-blue-100 hover:bg-blue-200 transition-colors">
                                <i class="bi-robot"></i>
                                Kommentár
                            </summary>

                            {% if exactCommentaries is not empty %}
                                <div class="px-4">
                                    {% for commentaryData in exactCommentaries %}
                                        <p class="font-semibold text-gray-800 mb-2">Kommentár a pontos szentírási helyhez:</p>
                                        
                                        <div class="space-y-4" id="exact-commentaries-{{ loop.index0 }}">
                                            {# Edit button for editors #}
                                            {% if isEditor and commentaryData.commentary_id is defined %}
                                            <div class="mb-2 flex items-center justify-end">
                                                <a href="{{ route('editor.commentaries.show', commentaryData.commentary_id) }}" class="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-gray-200 text-gray-800 hover:bg-gray-300 transition-colors" title="Kommentár szerkesztése">
                                                    <i class="bi bi-pencil-square mr-1"></i> Szerkesztés
                                                </a>
                                            </div>
                                            {% endif %}
                                            
                                            <div class="commentary p-3 border-l-4 rounded-r shadow-sm">
                                                {# Verification state display #}
                                                {% if commentaryData.verification_level is defined %}
                                                    {% set config = verification_config[commentaryData.verification_level] ?? verification_config.none %}
                                                    <div class="mb-2 flex items-center">
                                                        <span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded {{ config.color }}">
                                                            <i class="bi {{ config.icon }} mr-1"></i>
                                                            <span class="text-xs">{{ config.label }}</span>
                                                        </span>
                                                    </div>
                                                {% endif %}
                                                
                                                <div data-content-origin="ai-assisted" class="commentary-text text-sm leading-relaxed text-gray-700">{{ commentaryData.commentary_text ? commentaryData.commentary_text|markdown_to_html|raw : '' }}
                                                </div>
                                                {% if commentaryData.references is defined and commentaryData.references is not empty %}
                                                    <ul>
                                                        {% for ref in commentaryData.references %}
                                                            <li><a href="{{ ref.ref }}" target="_blank" class="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-blue-100 text-blue-800 hover:bg-blue-200 transition-colors">
                                                                    {{ ref.ref }}</a>
                                                                    <span class="ml-1">– {{ ref.reason }}</span></li>
                                                        {% endfor %}
                                                    </ul>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="p-2">
                                    <p class="font-semibold text-gray-800 mb-2">A pontos szentírási helyhez még nincs kommentár</p>
                                </div>
                                {% if pendingCommentaries is empty and canGenerateCommentary %}
                                <div class="commentary-status-container" id="status-0">
                                    {# Status will be loaded via AJAX #}
                                </div>
                                <div class="commentary-generator border-top pt-1 mt-2">
                                    <form method="POST" action="{{ route('editor.commentaries.generate') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token() }}">
                                    <input type="hidden" name="reference" value="{{ verseContainer.bookRef.toString() }}">
                                    <input type="hidden" name="translation" value="{{ translation.abbrev }}">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" style="hyphens: none;">
                                        <i class="bi-robot"></i> Kommentár készítése mesterséges intelligenciával: {{ verseContainer.bookRef.toString() }} (kb. 1 perc)
                                    </button>
                                    </form>
                                </div>
                                {% elseif pendingCommentaries is empty and commentaryGenerationPossible %}
                                <div class="p-2 border-t border-gray-200 mt-4">
                                    Belépett felhasználóink kérhetnek mesterséges intelligenciával előállított kommentárt ehhez a szentírási helyhez. Ez a szolgáltatás jelenleg fejlesztés alatt áll, de hamarosan elérhető lesz.
                                </div>
                                {% endif %}

                            {% endif %}

                            {% if relatedCommentaries is not empty %}
                                <div class="p-2 border-t border-gray-200 mt-4">
                                    <p class="font-semibold text-gray-800 mb-2">Kapcsolódó kommentár:</p>
                                    {% for commentaryData in relatedCommentaries %}
                                        <div class="space-y-4">
                                            {# Edit button for editors #}
                                            {% if isEditor and commentaryData.commentary_id is defined %}
                                            <div class="mb-2 flex items-center justify-end">
                                                <a href="{{ route('editor.commentaries.show', commentaryData.commentary_id) }}" class="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-gray-200 text-gray-800 hover:bg-gray-300 transition-colors" title="Kommentár szerkesztése">
                                                    <i class="bi bi-pencil-square mr-1"></i> Szerkesztés
                                                </a>
                                            </div>
                                            {% endif %}
                                            
                                            <div class="commentary p-3 border-l-4 rounded-r shadow-sm">
                                                {# Verification state display #}
                                                {% if commentaryData.verification_level is defined %}
                                                    {% set config = verification_config[commentaryData.verification_level] ?? verification_config.none %}
                                                    <div class="mb-2 flex items-center">
                                                        <span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded {{ config.color }}">
                                                            <i class="bi {{ config.icon }} mr-1"></i>
                                                            <span class="text-xs">{{ config.label }}</span>
                                                        </span>
                                                    </div>
                                                {% endif %}
                                                
                                                <div data-content-origin="ai-assisted" class="commentary-text text-sm leading-relaxed text-gray-700">{{ commentaryData.commentary_text ? commentaryData.commentary_text|markdown_to_html|raw : '' }}
                                                </div>
                                                {% if commentaryData.references is defined and commentaryData.references is not empty %}
                                                    <ul>
                                                        {% for ref in commentaryData.references %}
                                                            <li><a href="{{ ref.ref }}" target="_blank" class="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-blue-100 text-blue-800 hover:bg-blue-200 transition-colors">
                                                                    {{ ref.ref }}</a>
                                                                    <span class="ml-1">– {{ ref.reason }}</span></li>
                                                        {% endfor %}
                                                    </ul>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {% if pendingCommentaries is not empty %}
                                    <div class="commentary-pending-placeholder"
                                         data-container-index="{{ loop.index0 }}"
                                         data-reference="{{ containerReference }}"
                                         data-translation="{{ translation.abbrev }}"
                                         id="pending-exact-{{ loop.index0 }}">
                                        <div class="border border-yellow-200 rounded-lg bg-yellow-50 overflow-hidden">
                                            <div class="flex items-center px-4 py-3 bg-yellow-100">
                                                <span class="loading mr-2">⏳</span>
                                                <span class="text-sm text-gray-700">{{ containerReference }}: kommentár létrehozása folyamatban...</span>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                        </details>
                    </div>
                {% else %}
                    {% if canGenerateCommentary %}
                        <div class="commentary-status-container" id="status-0">
                                {# Status will be loaded via AJAX #}
                        </div>
                        <div class="commentary-generator border-top pt-1 mt-2">
                            <form method="POST" action="{{ route('editor.commentaries.generate') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token() }}">
                                <input type="hidden" name="reference" value="{{ verseContainer.bookRef.toString() }}">
                                <input type="hidden" name="translation" value="{{ translation.abbrev }}">
                                <button type="submit" class="btn btn-sm btn-outline-secondary" style="hyphens: none;">
                                    <i class="bi-robot"></i> Kommentár készítése mesterséges intelligenciával (kb. 1 perc)
                                </button>
                            </form>
                        </div>
                    {% elseif pendingCommentaries is empty and commentaryGenerationPossible %}
                    <div class="p-2 border-top mt-4">
                        <i class="bi-robot"></i> Belépett felhasználóink kérhetnek mesterséges intelligenciával előállított kommentárt ehhez a szentírási helyhez.
                    </div>
                    {% endif %}
                {% endif %}
            </div>
            {% set hasFootnote = false %}
            {% for verse in verseContainer.parsedVerses %}
                {% if verse.footnotes is not empty %}
                    {% if not hasFootnote %}
                    <div class="footnotes parsedVerses">
                        <details class="overflow-hidden" {% if not readingPlanDay %}open{% endif %}>
                            <summary class="h6 cursor-pointer flex items-center bg-gray-100 hover:bg-gray-200 transition-colors px-3 py-2 rounded-t">
                                <i class="bi-journal-text mr-2"></i>
                                Jegyzetek
                            </summary>
                            <div class="px-3 py-2">
                    {% set hasFootnote = true %}
                    {% endif %}
                    {% for footnote in verse.footnotes %}
                        <p class="footnote"><strong>{{ verse.chapter }},{{ verse.numv }}</strong>
                            {{ footnote.text|raw }}</p>
                    {%endfor %}
                {% endif %}
            {% endfor %}
            {% if hasFootnote %}
                            </div>
                        </details>
                    </div>
            {% endif %}
            </div>
            {%  if chapterLinks %}
                <ul class="pagination" id="pagination-{{ loop.index0 }}">
                    {% if chapterLinks.prevLink %}
                        <li class="page-item">
                            <a href="/{{ chapterLinks.prevLink }}{{ mediaEnabled ? '?media' : '' }}" class="page-link"><i class="bi-chevron-left"></i> Előző {{ verseContainer.book.usx_code != "PSA" ? "fejezet" : "zsoltár"}}</a>
                        </li>
                    {% endif %}
                        {% if chapterLinks.nextLink %}
                            <li class="page-item">
                            <a href="/{{ chapterLinks.nextLink }}{{ mediaEnabled ? '?media' : '' }}" role="button" class="page-link">Következő {{ verseContainer.book.usx_code != "PSA" ? "fejezet" : "zsoltár"}} <i class="bi bi-chevron-right"></i></a>
                        </li>
                        {% endif %}
                  </ul>
                
                {# Floating navigation control that appears when pagination is out of view #}
                <div class="floating-pagination-{{ loop.index0 }}" style="position: fixed; bottom: 20px; right: 20px; display: none; z-index: 1050; gap: 4px;">
                    {% if chapterLinks.prevLink %}
                        <a href="/{{ chapterLinks.prevLink }}{{ mediaEnabled ? '?media' : '' }}" style="width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; background-color: rgba(0, 0, 0, 0.7); color: white; border-radius: 4px; text-decoration: none; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='rgba(0, 0, 0, 0.9)'; this.style.transform='scale(1.1)';" onmouseout="this.style.backgroundColor='rgba(0, 0, 0, 0.7)'; this.style.transform='scale(1)';" title="Előző {{ verseContainer.book.usx_code != "PSA" ? "fejezet" : "zsoltár"}}">
                            <i class="bi-chevron-left"></i>
                        </a>
                    {% endif %}
                    {% if chapterLinks.nextLink %}
                        <a href="/{{ chapterLinks.nextLink }}{{ mediaEnabled ? '?media' : '' }}" style="width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; background-color: rgba(0, 0, 0, 0.7); color: white; border-radius: 4px; text-decoration: none; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='rgba(0, 0, 0, 0.9)'; this.style.transform='scale(1.1)';" onmouseout="this.style.backgroundColor='rgba(0, 0, 0, 0.7)'; this.style.transform='scale(1)';" title="Következő {{ verseContainer.book.usx_code != "PSA" ? "fejezet" : "zsoltár"}}">
                            <i class="bi-chevron-right"></i>
                        </a>
                    {% endif %}
                </div>
                
                <script>
                    (function() {
                        const paginationId = 'pagination-{{ loop.index0 }}';
                        const floatingClass = 'floating-pagination-{{ loop.index0 }}';
                        const pagination = document.getElementById(paginationId);
                        const floatingNav = document.querySelector('.' + floatingClass);
                        
                        if (pagination && floatingNav) {
                            const observer = new IntersectionObserver((entries) => {
                                entries.forEach(entry => {
                                    if (entry.isIntersecting) {
                                        floatingNav.style.display = 'none';
                                    } else {
                                        floatingNav.style.display = 'flex';
                                    }
                                });
                            }, {
                                threshold: 0.1
                            });
                            
                            observer.observe(pagination);
                        }
                    })();
                </script>
            {% endif %}
    <hr>
{% endfor %}
