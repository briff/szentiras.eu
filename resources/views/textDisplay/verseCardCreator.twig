{% extends 'layout.twig' %}

{% block pageHeader %}
<h1>Igés kártya készítő</h1>
{% endblock %}

{% block content %}
<div class="tailwind-scope">
<div id="verseCardCreator" class="verse-card-creator" data-session-id="{{ sessionId }}" data-csrf-token="{{ csrf_token() }}">
    
    <!-- Loading state while session initializes -->
    <div id="loadingState" class="text-center py-12">
        <div class="spinner-border mb-4" role="status">
            <span class="visually-hidden">Betöltés...</span>
        </div>
        <p id="statusMessage" class="text-muted">Inicializálás...</p>
    </div>

    <!-- Candidate chooser state -->
    <div id="candidateChooserState" style="display: none;">
        <div class="mb-6">
            <h2 class="h4 mb-2">Válassz egy képet</h2>
            <p class="text-muted">Kattints a képre a kiválasztáshoz</p>
        </div>

        <!-- Candidate thumbnails grid -->
        <div id="candidatesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <!-- Candidates will be inserted here -->
        </div>

        <!-- More button -->
        <div class="flex justify-center mb-4">
            <button id="moreButton" class="btn btn-outline-primary px-6 py-2 font-medium" type="button">
                <span class="spinner-border spinner-border-sm me-2" id="moreSpinner" style="display: none;" role="status" aria-hidden="true"></span>
                <span id="moreButtonText">Több kép</span>
            </button>
        </div>
    </div>

    <!-- Final preview state -->
    <div id="finalPreviewState" style="display: none;">
        <div class="mb-6">
            <h2 class="h4 mb-2">Előnézet</h2>
        </div>

        <!-- Final preview image -->
        <div class="text-center mb-6">
            <img id="finalPreviewImage" src="" alt="Végső előnézet" class="img-fluid rounded shadow-lg" style="max-width: 100%; max-height: 600px; object-fit: contain;">
        </div>

        <!-- Edit fields section -->
        <div id="editFieldsSection" class="mb-6 p-4 bg-light rounded border border-gray-200">
            <h3 class="h5 mb-4">Szöveg szerkesztése</h3>
            
                <form id="editFieldsForm" class="space-y-4">
                    <div>
                        <input
                            type="text"
                            class="form-control block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring focus:ring-primary-200 focus:ring-opacity-50"
                            id="verseRefInput"
                            placeholder="pl. Róm 3:23"
                            value="{{ session.verse_ref }}"
                        >
                    </div>
                    <div>
                        <textarea
                            class="form-control block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring focus:ring-primary-200 focus:ring-opacity-50"
                            id="verseTextInput"
                            rows="4"
                            placeholder="Vers szövege..."
                        >{{ session.verse_text }}</textarea>
                    </div>
                </form>

            <div class="flex gap-2">
                <button id="saveEditsButton" class="btn btn-success px-4 py-2 font-medium" type="button">
                    <i class="bi bi-check-circle me-2"></i>Mentés és újrarenderelés
                </button>
                <button id="cancelEditsButton" class="btn btn-outline-secondary px-4 py-2 font-medium" type="button">
                    <i class="bi bi-x-circle me-2"></i>Mégse
                </button>
            </div>
        </div>

        <!-- Download button -->
        <div class="flex justify-center gap-3">
            <a id="downloadButton" href="" class="btn btn-primary px-6 py-2 font-medium" download>
                <i class="bi bi-download me-2"></i>Letöltés
            </a>
            <button id="newCardButton" class="btn btn-outline-secondary px-6 py-2 font-medium" type="button">
                <i class="bi bi-plus-circle me-2"></i>Új kártya
            </button>
        </div>
    </div>

    <!-- Error state -->
    <div id="errorState" class="alert alert-danger p-4" style="display: none;" role="alert">
        <h4 class="alert-heading font-semibold mb-2">Hiba történt</h4>
        <p id="errorMessage" class="mb-3"></p>
        <hr class="my-2">
        <button id="retryButton" class="btn btn-sm btn-outline-danger" type="button">Újra</button>
    </div>
</div>
</div>

<script>
    // Pass initial data to JavaScript
    window.verseCardData = {
        sessionId: '{{ sessionId }}',
        csrfToken: '{{ csrf_token() }}'
    };
</script>
{% endblock %}

{% block script %}
{{ vite('resources/assets/css/verseCardCreator.css')|raw }}
{{ vite('resources/assets/js/verseCardCreator.js')|raw }}
{% endblock %}
