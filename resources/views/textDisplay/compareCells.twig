{#
  Reusable per-verse renderers for the aligned comparison grid (see compareVerseGrid.twig).

  Each cell is self-contained: it does not rely on cross-verse continuity (poem/inline state)
  the way parsedVerseContainer.twig does, because every verse lives in its own grid cell.

  - verseCell: renders a single parsed verse (number, text/poem/inline-heading parts, xrefs,
    place icon), reusing the numv/xrefs/placeIcon macros from parsedVerseContainer.twig.
  - greekCell: renders a single Greek verse with clickable words, matching the markup used by
    the reading page so the word panel and AI-tools toggle keep working.
#}
{% macro verseCell(verse, translation, verseToPlaces, highlightedGepis) %}
    {% import 'textDisplay.parsedVerseContainer' as pv %}
    {% set mark = verse.gepi in (highlightedGepis|default([])) %}
    {% set verseToPlaces = verseToPlaces|default({}) %}
    <div class="parsedVerses">
        {% if verse.numv == 1 %}<span class="numchapter">{{ verse.chapter }}</span>{% endif %}
        {% set inPoem = false %}
        {% set verseNumberWritten = false %}
        {%- for versePart in verse.verseParts -%}
            {% if versePart.poem %}
                {% if not inPoem %}<p class="poem {{ mark ? 'mark' : '' }}">{% set inPoem = true %}{% endif %}
                {%- if not verseNumberWritten %}{{ pv.numv(verse, mark) }}{% set verseNumberWritten = true %}{% endif %}
                {{ versePart.content|raw }}{% if versePart.last %}{{ pv.xrefs(verse, translation, mark) }}{{ pv.placeIcon(verse, verseToPlaces) }}</p>{% else %}<br>{% endif %}
            {% elseif versePart.heading %}
                {%- if inPoem %}</p>{% set inPoem = false %}{% endif -%}
                {%- if versePart.headingLevel < 6 -%}
                    {%- set tag = 'h' ~ (versePart.headingLevel+1) -%}
                {%- else -%}
                    {%- set tag = 'span' %}{% set extraclass = 'heading' ~ (versePart.headingLevel + 1) ~ (mark ? ' mark' : '') -%}
                {%- endif -%}
                <{{ tag|raw }} class="heading {{ extraclass }}" id="heading_{{ verse.gepi }}_{{ versePart.headingLevel }}">{{ versePart.content|striptags('<br><a>')|raw }}</{{ tag }}>
            {%- else -%}
                {%- if inPoem %}</p>{% set inPoem = false %}{% endif -%}
                {%- if not verseNumberWritten %}{{ pv.numv(verse, mark) }}{% set verseNumberWritten = true %}{% endif -%}
                <span class="{{ mark ? 'mark' : '' }}">{{ versePart.content|raw }} </span>
                {%- if versePart.last %}{{ pv.xrefs(verse, translation, mark) }}{{ pv.placeIcon(verse, verseToPlaces) }}{% endif -%}
                {%- if versePart.newline %}<br>{% endif -%}
            {%- endif -%}
        {%- endfor -%}
    </div>
{% endmacro %}

{% macro greekCell(greekVerse) %}
    <div class="compareGreek greek greekSection" lang="grc">
        <span class="numv"><sup>{{ greekVerse.verse }}</sup></span><span class="verse-text">{% include 'greekText.clickableGreekText' with {'words': greekVerse.annotatedWords} %}</span>
    </div>
{% endmacro %}
