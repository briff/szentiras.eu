{#
  Renders the Greek (GNT) text in the comparison column, aligned with the primary
  translation's verse containers. Greek words are clickable and open the word panel
  (see resources/assets/js/greekWordPanel.js).

  The wrapper deliberately avoids the `parsedVerses` class so the AI-tools toggle
  (which hides `.parsedVerses span.numv`) does not strip the verse numbers here, while
  the verse-number toggle (which targets `.numv, .numchapter` globally) still works.
#}
{% for verseContainer in verseContainers %}
    {% set containerIndex = loop.index0 %}
    <div>
        {% include 'textDisplay.breadcrumb' with {'book': verseContainer.book, 'bookRef': verseContainer.bookRef, 'translation': compareTranslation } %}
    </div>
    <div class="compareGreek greek greekSection mb-2" lang="grc">
        {% set displayedChapter = null %}
        {% for greekVerse in compareGreekVerses[containerIndex] %}
            {% if displayedChapter != greekVerse.chapter %}
                <span class="numchapter">{{ greekVerse.chapter }}</span>
                {% set displayedChapter = greekVerse.chapter %}
            {% endif %}
            <span class="numv"><sup>{{ greekVerse.verse }}</sup></span><span class="verse-text">{% include 'greekText.clickableGreekText' with {'words': greekVerse.annotatedWords} %}</span>
        {% endfor %}
    </div>
    <hr>
{% endfor %}
{% include 'greekText.greekWordOffcanvas' %}
