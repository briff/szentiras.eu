{% extends 'layout' %}

{% set loadCommentaryPolling = true %}

{% block meta %}
    <link rel="canonical" href="{{ url('/' ~ seoUrl ) }}" />
    {% if seoUrl != canonicalUrl or mediaEnabled or fullContext or compareTranslation %}
        <meta name="robots" content="noindex,follow">
    {% endif %}

    <meta property="og:url" content="{{ url('/' ~ canonicalUrl ) }}">
    <meta property="og:title" content="{{ metaTitle }}">
    <meta property="og:description" content="{{ teaser }}">
	<meta property="og:image" content="{{ asset('img/biblia.jpg')}}">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}

{% block content %}
    <div class="modal fade" id="qrModal" tabindex="-1" role="dialog">
        <div class="modal-dialog"><div class="modal-content"></div></div>
    </div>
    <div class="modal fade" id="pdfModal" tabindex="-1" role="dialog">
        <div class="modal-dialog"><div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nyomtatás/PDF</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
            <a tabindex="0" id="pdfDownload" class="btn btn-primary"><i class="bi-printer"></i> Nyomtatási kép létrehozása</a>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezárás</button>
            </div>
        </div></div>
    </div>
    <div class="modal fade" id="placeModal" tabindex="-1" aria-labelledby="placeModalLabel">
        <div class="modal-dialog modal-dialog-centered modal-lg" style="max-width: 750px; height: 90vh;">
            <div class="modal-content" style="height: 90vh;">
                <div class="modal-header">
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="placeModalBody" style="height: calc(90vh - 56px); overflow-y: auto;">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Betöltés...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="verseCardModal" tabindex="-1" role="dialog">
        <div class="modal-dialog"><div class="modal-content"></div></div>
    </div>
    {% if readingPlanDay %}
    <div>
        <h1>
            <a href="/tervek/{{ readingPlanDay.plan_id }}">{{ readingPlan.name }}</a> - {{ readingPlanDay.day_number }}. nap
        </h1>
        <h4>
            {{ (readingPlanDay.description|raw ~ (readingPlanDay.description ? ', ' : '') ~ readingPlanDay.verses|replace({';': ', '}))|trim }}
        </h4>
        <br>
    </div>
            {# <div class="col-12">
                <p class="lead mb-2">
                    <strong>{{ readingPlanDay.day_number }}. nap</strong> - 
                    <span class="text-muted">{{ readingPlanDay.description|raw }}</span>
                </p>
                <p class="small text-secondary">
                    {{ readingPlanDay.verses|replace({';': ', '}) }}
                </p>
            </div> #}
    {% endif %}
    {% if not readingPlanDay and metaReference %}
        <h1 class="h4">{{ metaReference }}</h1>
    {% endif %}
    <div class="translationButtons">
        {% include 'textDisplay.translationButtons' with { 'translations': translations, 'translation': translation, 'mediaEnabled': mediaEnabled} %}
    </div>

    {% if not fullChaptersIncluded and not fullContext %}
    <a class="btn btn-info" id="fullContextButton" href="{{ url('/' ~ canonicalUrl ~ '?fullContext' ~ (mediaEnabled ? '&media' : '' )) }}" title="Teljes szövegkörnyezet megjelenítése">
        <i class="bi-chevron-expand"></i> Teljes szövegkörnyezet megjelenítése</a>
    {% endif %}
    {% if fullContext %}
        <a class="btn btn-info" id="fullContextButton" href="{{ url('/' ~ canonicalUrl ~ (mediaEnabled ? '?media' : '')) }}" title="Csak a hivatkozás szövegének megjelenítése">
            <i class="bi-chevron-contract"></i> Csak a hivatkozás szövegének megjelenítése</a>
    {% endif %}
    <span id="data" {% if scrollTo %} data-scroll-to="{{ scrollTo }}" {% endif %}></span>
    {% if compareTranslation and (compareVerseContainers or compareGreekVerses) %}
        <div class="row">
            <div class="col-lg-6">
                <h5>{{ translation.name }}</h5>
                {{ include('textDisplay.verseContainers') }}
            </div>
            <div class="col-lg-6">
                <h5>{{ compareTranslation.name }}</h5>
                {% if compareGreekVerses %}
                    {{ include('textDisplay.compareGreekVerses') }}
                {% else %}
                    {{ include('textDisplay.compareVerseContainers') }}
                {% endif %}
            </div>
        </div>
    {% else %}
        {{ include('textDisplay.verseContainers') }}
    {% endif %}
    {% if previousDay %}
        <a href="/tervek/{{ previousDay.plan_id }}/{{ previousDay.day_number }}" class="btn btn-primary btn-default"><i class="bi bi-chevron-left"></i> Előző nap</a>
    {% endif %}
    {% if readingPlanDay %}
        <a href="/tervek/{{ readingPlanDay.plan_id }}" class="btn btn-primary btn-default"><span class="btn-primary"><i class="bi bi-chevron-up"></i></span> Olvasási terv</a>
    {% endif %}
    {% if nextDay %}
        <a href="/tervek/{{ nextDay.plan_id }}/{{ nextDay.day_number }}" class="btn btn-primary btn-default">Következő nap <i class="bi bi-chevron-right"></i></a>
    {% endif %}
    {% if fullChaptersIncluded and not fullContext and not readingPlanDay %}
    <div class="card bg-light mb-2">
        <div class="card-header collapsible" data-bs-toggle="collapse" data-bs-target="#cardContent">
            <i class="bi bi-chevron-down"></i>
            Minden {{ verseContainers[0].book.usx_code != "PSA" ? "fejezet" : "zsoltár"}}...
        </div>
        <div id="cardContent" class="collapse">
            <div class="card-body">
                <div class="chapterButtons">
                    {{ include('textDisplay.chapterButtons', { 'bookAbbrev': verseContainers[0].book.abbrev, 'maxChapter': chapterLinks.chapterCount, 'actualChapter': verseContainers[0].parsedVerses[0].chapter}) }}
                </div>
            </div>
        </div>
    </div>
    {% endif %}
    {% if mediaEnabled and otherMedia %}
        {% from 'macros' import image %}
        <h5>További illusztrációk</h5>
        {% for otherMediaItem in otherMedia %}
            {% for image in otherMediaItem %}
                {{ image(image, isEditor) }}
            {% endfor  %}
        {% endfor %}
        <hr>
    {% endif %}
    <div class="translationButtons">
        {{ include('textDisplay.translationButtons') }}
    </div>
    {{ include('textDisplay.share') }}
{% endblock %}

{% block extramenu %}
    <div class="card">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm active" id="toggleNumv" title="Versszámozás" style="background-color: #0d6efd; color: white;">
                    <i class="bi-123"></i>
                </button>
                <button type="button" class="btn btn-sm active" id="toggleXrefs" title="Hivatkozások" style="background-color: #0d6efd; color: white;">
                    <i class="bi-link-45deg"></i>
                </button>
                <button type="button" class="btn btn-sm active" id="toggleHeadings" title="Címsorok" style="background-color: #0d6efd; color: white;">
                    <i class="bi-card-heading"></i>
                </button>
                <button type="button" class="btn btn-sm inactive" id="toggleAiTools" title="Segédeszközök" style="background-color: transparent; color: #0d6efd; border: 1px solid #0d6efd;">
                    <i class="bi-tools"></i>
                </button>
                {% if not mediaEnabled %}
                    <a class="btn btn-sm {{ hasMedia ? '' : 'd-none' }}" id="mediaButton" href="{{ url('/' ~ canonicalUrl ~ '?media' ~ (fullContext ? '&fullContext' : '')) }}" title="Illusztrációk megjelenítése">
                        <i class="bi-images"></i>
                    </a>
                {% endif %}
                {% if mediaEnabled %}
                    <a class="btn btn-sm {{ hasMedia ? '' : 'd-none' }}" id="mediaButton" href="{{ url('/' ~ canonicalUrl ~ (fullContext ? '?fullContext' : '')) }}" title="Illusztrációk elrejtése">
                        <i class="bi-images"></i>
                    </a>
                {% endif %}
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-sm {% if compareTranslation %}active{% else %}inactive{% endif %}" data-bs-toggle="dropdown" title="Fordítások összehasonlítása" style="{% if compareTranslation %}background-color: #0d6efd; color: white;{% else %}background-color: transparent; color: #0d6efd; border: 1px solid #0d6efd;{% endif %}">
                        <i class="bi-columns-gap"></i>
                    </button>
                    <ul class="dropdown-menu">
                        {% if compareTranslation %}
                            <li><span class="dropdown-item-text"><strong>{{ compareTranslation.name }}</strong></span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ url('/' ~ canonicalUrl ~ (mediaEnabled ? '?media' : '')) }}">
                                <i class="bi-x"></i> Összehasonlítás bezárása
                            </a></li>
                        {% else %}
                            {% for otherTranslation in translationLinks %}
                                {% if otherTranslation.id != translation.id and otherTranslation.enabled %}
                                    <li><a class="dropdown-item" href="{{ url('/' ~ canonicalUrl ~ '?compare=' ~ otherTranslation.abbrev ~ (mediaEnabled ? '&media' : '')) }}">
                                        {{ otherTranslation.abbrev }}
                                    </a></li>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% if isEditor and mediaEnabled %}
    {% set js=['pages/verses', 'editor-media-move', 'commentary-status-polling'] %}
{% else %}
    {% set js=['pages/verses', 'commentary-status-polling'] %}
{% endif %}

{% block script %}
    {{ parent() }}
{% endblock %}