{% extends "layout" %}

{% block pageHeader %}
    <div class="page-header">
        <h1>Szentírás.eu <span class="hidden-xs hidden-sm sitesubtitle">Digitális Biblia 2012 óta. (Régi <b>szentiras.hu</b>)</span></h1>
    </div>
{%  endblock %}

{% block content %}
    <div class="container-fluid px-0">
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-6">
                {% include 'readTile' %}
            </div>
            
            <div class="col-12 col-lg-6">
                {% include 'searchTile' %}
            </div>
        </div>

        <div class="row g-3 mb-4">
            <!-- Translation select tile (1 wide) -->
            <div class="col-12 col-md-6 col-lg-3">
                {% include 'translationTile' with { cathBibles: cathBibles, otherBibles: otherBibles } %}
            </div>
            
            <!-- New Testament tile (1 wide) -->
            <div class="col-12 col-md-6 col-lg-3">
                {% include 'newTestamentTile' %}
            </div>
            
            <!-- Old Testament tile (1 wide) -->
            <div class="col-12 col-md-6 col-lg-3">
                {% include 'oldTestamentTile' %}
            </div>
            
            <!-- Psalms tile (1 wide) -->
            <div class="col-12 col-md-6 col-lg-3">
                {% include 'psalmsTile' %}
            </div>
        </div>

        <!-- Additional tiles section (for future expansion) -->
        <div class="row g-3">
            <div class="col-12">
                <div class="card border-0" style="background-color: #f8f7f4;">
                    <div class="card-header border-0" style="background-color: #f0ede8; color: #6b6560;">
                        <i class="bi-grid-3x3-gap me-2"></i>
                        További lehetőségek
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                           
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="card h-100 border-0" style="background-color: #f0ede8;">
                                    <div class="card-body text-center">
                                        <div class="d-flex align-items-center justify-content-center mb-3">
                                            <i class="bi-calendar-week display-5 me-3" style="color: #7a9e87;"></i>
                                            <h5 class="card-title mb-0" style="color: #4a5568;">Olvasási tervek</h5>
                                        </div>
                                        <p class="card-text d-none d-md-block" style="color: #718096;">Napi olvasási tervek a Bibliából</p>
                                        <a href="/tervek" class="btn" style="color: #7a9e87; border-color: #7a9e87; background: transparent;">Megnyitás</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="card h-100 border-0" style="background-color: #f0ede8;">
                                    <div class="card-body text-center">
                                        <div class="d-flex align-items-center justify-content-center mb-3">
                                            <i class="bi-search-heart display-5 me-3" style="color: #b08d6a;"></i>
                                            <h5 class="card-title mb-0" style="color: #4a5568;">MI Keresés</h5>
                                        </div>
                                        <p class="card-text d-none d-md-block" style="color: #718096;">Keresés mesterséges intelligenciával</p>
                                        <a href="/ai-search" class="btn" style="color: #b08d6a; border-color: #b08d6a; background: transparent;">Megnyitás</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="card h-100 border-0" style="background-color: #f0ede8;">
                                    <div class="card-body text-center">
                                        <div class="d-flex align-items-center justify-content-center mb-3">
                                            <i class="bi-info-circle display-5 me-3" style="color: #7b9bb5;"></i>
                                            <h5 class="card-title mb-0" style="color: #4a5568;">Információk</h5>
                                        </div>
                                        <p class="card-text d-none d-md-block" style="color: #718096;">A projektről és használati útmutató</p>
                                        <a href="/informaciok" class="btn" style="color: #7b9bb5; border-color: #7b9bb5; background: transparent;">Megnyitás</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="card h-100 border-0" style="background-color: #f0ede8;">
                                    <div class="card-body text-center">
                                        <div class="d-flex align-items-center justify-content-center mb-3">
                                            <i class="bi-tools display-5 me-3" style="color: #8b8fa8;"></i>
                                            <h5 class="card-title mb-0" style="color: #4a5568;">Fejlesztőknek</h5>
                                        </div>
                                        <p class="card-text d-none d-md-block" style="color: #718096;">API és fejlesztői dokumentáció</p>
                                        <a href="/api" class="btn" style="color: #8b8fa8; border-color: #8b8fa8; background: transparent;">Megnyitás</a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block abbrevlist %}
    {% include 'bookAbbrevList' %}
{% endblock %}

{% set js = ['pages/home'] %}