{% extends 'layout' %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ route('editor.contactMessages.index') }}">Szerkesztői beérkezett üzenetek</a></li>
                    <li class="breadcrumb-item active">Beszélgetés #{{ message.id }}</li>
                </ol>
            </nav>

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Eredeti üzenet</h5>
                    <div>
                        {% if message.isResolved() %}
                            <span class="badge bg-success">Lezárt</span>
                        {% else %}
                            <span class="badge bg-warning">Nyitott</span>
                        {% endif %}
                        <small class="text-muted ms-2">{{ message.created_at|date('Y. m. d. H:i') }}</small>
                    </div>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-start mb-3">
                        <div class="flex-shrink-0">
                            <i class="bi bi-person-circle fs-4"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="mb-1">
                                {% if message.sender %}
                                    <span class="badge bg-primary">Felhasználó</span>
                                    <code>{{ message.sender.token }}</code>
                                {% else %}
                                    <span class="badge bg-secondary">Vendég</span>
                                {% endif %}
                            </h6>
                            <p class="mb-0">{{ message.message|nl2br }}</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <div>
                            {% if not message.isResolved() %}
                                <form method="post"
                                      action="{{ route('editor.contactMessages.resolve', message.id) }}"
                                      class="d-inline">
                                    {{ csrf_field() }}
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-check-circle"></i> Lezárás
                                    </button>
                                </form>
                            {% endif %}
                            <form method="post"
                                  action="{{ route('editor.contactMessages.delete', message.id) }}"
                                  class="d-inline ms-2"
                                  onsubmit="return confirm('Biztosan törlöd ezt az üzenetet? A törlés végleges!')">
                                {{ csrf_field() }}
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Törlés
                                </button>
                            </form>
                        </div>
                        <div>
                            <a href="{{ route('editor.anonymousIds.index') }}" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-people"></i> Felhasználók listája
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            {% if message.replies.count > 0 %}
                <h5 class="mb-3">Válaszok ({{ message.replies.count }})</h5>
                {% for reply in message.replies %}
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0">
                                    <i class="bi bi-person-circle fs-4"></i>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0">
                                            {% if reply.sender %}
                                                <span class="badge bg-info">Szerkesztő</span>
                                                <code>{{ reply.sender.token|slice(0, 8) }}…</code>
                                            {% else %}
                                                <span class="badge bg-secondary">Ismeretlen</span>
                                            {% endif %}
                                        </h6>
                                        <small class="text-muted">{{ reply.created_at|date('Y. m. d. H:i') }}</small>
                                    </div>
                                    <p class="mb-0">{{ reply.message|nl2br }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

            {% if not message.isResolved() and message.sender %}
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Válasz küldése</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ route('editor.contactMessages.reply', message.id) }}">
                            {{ csrf_field() }}
                            <div class="mb-3">
                                <label for="reply" class="form-label">Válasz szövege</label>
                                <textarea
                                    id="reply"
                                    name="reply"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Írja ide válaszát…"
                                    required
                                >{{ old('reply') }}</textarea>
                                {% if errors.has('reply') %}
                                    <div class="invalid-feedback d-block">{{ errors.first('reply') }}</div>
                                {% endif %}
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Válasz küldése
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            {% elseif not message.sender %}
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> Ez egy vendégüzenet, nem lehet rá válaszolni.
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}