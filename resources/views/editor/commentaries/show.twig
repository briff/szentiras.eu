{% extends 'layout.twig' %}

{% block pageHeader %}
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1>Kommentár szerkesztése</h1>
            <p class="text-muted">
                <span class="badge bg-primary">{{ commentary.translation.abbrev }}</span>
                <span class="badge bg-secondary">{{ book.abbrev }}</span>
            </p>
        </div>
        <div class="d-flex gap-2">
            {% if commentaryData.reference is defined and commentaryData.reference %}
                <a href="/{{ commentary.translation.abbrev }}/{{ commentaryData.reference }}" class="btn btn-outline-primary" title="Ugrás a szentírási helyhez">
                    <i class="bi bi-book"></i> Szentírási hely megtekintése
                </a>
            {% endif %}
            <a href="{{ route('editor.commentaries.index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Vissza a listához
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="commentary-editor">
    <div class="row">
        <div class="col-lg-8">
            <!-- Commentary Details with Tabs -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <ul class="nav nav-tabs card-header-tabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="commentary-tab" data-bs-toggle="tab" data-bs-target="#commentary-content" type="button" role="tab" aria-controls="commentary-content" aria-selected="true">
                                <i class="bi bi-pencil"></i> Kommentár szerkesztése
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="source-tab" data-bs-toggle="tab" data-bs-target="#source-content" type="button" role="tab" aria-controls="source-content" aria-selected="false">
                                <i class="bi bi-file-text"></i> Forrásszöveg
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="tab-content">
                    <!-- Commentary Tab -->
                    <div class="tab-pane fade show active" id="commentary-content" role="tabpanel" aria-labelledby="commentary-tab">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="mb-0">Kommentár szövege</h5>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="toggle-edit-text">
                                    <i class="bi bi-pencil"></i> Szerkesztés
                                </button>
                            </div>
                            
                            <!-- Display mode -->
                            <div class="commentary-text-display" id="commentary-text-display">
                                {% apply markdown_to_html %}
{{ commentaryData.commentary_text }}
                                {% endapply %}
                            </div>
                            
                            <!-- Edit mode (hidden by default) -->
                            <div class="commentary-text-edit" id="commentary-text-edit" style="display: none;">
                                <form method="POST" action="{{ route('editor.commentaries.update', commentary.id) }}" id="commentary-text-form">
                                    {{ csrf_field() }}
                                    <input type="hidden" name="_method" value="PUT">
                                    
                                    <div class="mb-3">
                                        <label for="commentary_text" class="form-label">Kommentár szöveg (Markdown formátumban)</label>
                                        <textarea class="form-control font-monospace" id="commentary_text" name="commentary_text" rows="15">{{ commentaryData.commentary_text }}</textarea>
                                        <div class="form-text">
                                            Használhatja a Markdown formázást: **félkövér**, *dőlt*, `kód`, listák, stb.
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex justify-content-between">
                                        <button type="button" class="btn btn-outline-secondary" id="cancel-edit-text">
                                            <i class="bi bi-x-circle"></i> Mégse
                                        </button>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-check-circle"></i> Mentés
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Source Text Tab -->
                    <div class="tab-pane fade" id="source-content" role="tabpanel" aria-labelledby="source-tab">
                        <div class="card-body">
                            <h5 class="mb-3">Forrásszöveg</h5>
                            {% if commentary.source_text %}
                                <div class="source-text-display">
                                    {% apply markdown_to_html %}
{{ commentary.source_text }}
                                    {% endapply %}
                                </div>
                            {% else %}
                                <p class="text-muted mb-0">Nincs forrásszöveg definiálva.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- References Section -->
            <div class="card mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Hivatkozások</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="toggle-edit-references">
                        <i class="bi bi-pencil"></i> Szerkesztés
                    </button>
                </div>
                <div class="card-body">
                    <!-- Display mode -->
                    <div id="references-display">
                        {% if commentaryData.references and commentaryData.references|length > 0 %}
                            <ul class="list-unstyled">
                                {% for reference in commentaryData.references %}
                                    <li class="mb-3">
                                        <strong>{{ reference.ref }}</strong>
                                        <p class="mb-0 text-muted small">{{ reference.reason }}</p>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-muted mb-0">Nincsenek hivatkozások.</p>
                        {% endif %}
                    </div>
                    
                    <!-- Edit mode (hidden by default) -->
                    <div id="references-edit" style="display: none;">
                        <form method="POST" action="{{ route('editor.commentaries.update', commentary.id) }}" id="references-form">
                            {{ csrf_field() }}
                            <input type="hidden" name="_method" value="PUT">
                            <!-- Hidden field to indicate references form was submitted -->
                            <input type="hidden" name="references_form_submitted" value="1">
                            
                            <div id="references-edit-container">
                                {% if commentaryData.references and commentaryData.references|length > 0 %}
                                    {% for reference in commentaryData.references %}
                                        <div class="reference-edit-item mb-3 p-3 border rounded">
                                            <div class="row">
                                                <div class="col-md-5">
                                                    <label class="form-label">Hivatkozás</label>
                                                    <input type="text" class="form-control" name="references[{{ loop.index0 }}][ref]" value="{{ reference.ref }}" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Leírás / Indoklás</label>
                                                    <input type="text" class="form-control" name="references[{{ loop.index0 }}][reason]" value="{{ reference.reason }}">
                                                </div>
                                                <div class="col-md-1 d-flex align-items-end">
                                                    <button type="button" class="btn btn-outline-danger btn-sm remove-reference" data-index="{{ loop.index0 }}">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            
                            <div class="mb-3">
                                <button type="button" class="btn btn-outline-success btn-sm" id="add-reference">
                                    <i class="bi bi-plus-circle"></i> Új hivatkozás hozzáadása
                                </button>
                            </div>
                            
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary" id="cancel-edit-references">
                                    <i class="bi bi-x-circle"></i> Mégse
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i> Hivatkozások mentése
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Metadata -->
            {% if commentary.metadata %}
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Metaadatok</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        {% for key, value in commentary.metadata %}
                            <dt class="col-sm-3">{{ key }}</dt>
                            <dd class="col-sm-9">
                                {% if value is iterable %}
                                    <code>{{ value|json_encode }}</code>
                                {% else %}
                                    <code>{{ value }}</code>
                                {% endif %}
                            </dd>
                        {% endfor %}
                    </dl>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <!-- Sidebar Information -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Információ</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-6">Fordítás:</dt>
                        <dd class="col-sm-6">
                            <span class="badge bg-primary">{{ commentary.translation.abbrev }}</span>
                        </dd>

                        <dt class="col-sm-6">Könyv:</dt>
                        <dd class="col-sm-6">
                            <strong>{{ book.abbrev }}</strong>
                        </dd>

                        <dt class="col-sm-6">USX kód:</dt>
                        <dd class="col-sm-6">
                            <code>{{ commentary.usx_code }}</code>
                        </dd>

                        <dt class="col-sm-6">Versek:</dt>
                        <dd class="col-sm-6">
                            <small>{{ formattedRanges }}</small>
                        </dd>

                        <dt class="col-sm-6">Hossz:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.commentary_text|length }} karakter</small>
                        </dd>

                        <dt class="col-sm-6">Forrásszöveg:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.source_text|default('N/A')|slice(0, 100) }}{% if commentary.source_text and commentary.source_text|length > 100 %}...{% endif %}</small>
                        </dd>

                        <dt class="col-sm-6">Token felhasználás:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.token_usage|default('N/A') }}</small>
                        </dd>

                        <dt class="col-sm-6">Ellenőrzési szint:</dt>
                        <dd class="col-sm-6">
                            {% set verificationBadgeClass = 'bg-secondary' %}
                            {% if commentary.verification_level == 'none' %}
                                {% set verificationBadgeClass = 'bg-light text-dark' %}
                            {% elseif commentary.verification_level == 'sanity' %}
                                {% set verificationBadgeClass = 'bg-info' %}
                            {% elseif commentary.verification_level == 'theology' %}
                                {% set verificationBadgeClass = 'bg-success' %}
                            {% endif %}
                            <span class="badge {{ verificationBadgeClass }}">{{ commentary.verification_level }}</span>
                        </dd>

                        <dt class="col-sm-6">Létrehozva:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.created_at.format('Y-m-d H:i:s') }}</small>
                        </dd>

                        <dt class="col-sm-6">Módosítva:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.updated_at.format('Y-m-d H:i:s') }}</small>
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Verse Ranges -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Versek</h5>
                </div>
                <div class="card-body">
                    {% if commentary.ranges.count() > 0 %}
                        <ul class="list-unstyled">
                            {% for range in commentary.ranges %}
                                <li class="mb-2">
                                    <span class="badge bg-info">
                                        {{ range.start_chapter }}:{{ range.start_verse }} - {{ range.end_chapter }}:{{ range.end_verse }}
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">Nincsenek versek definiálva.</p>
                    {% endif %}
                </div>
            </div>

            <!-- Verification Level Update -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Ellenőrzési szint módosítása</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ route('editor.commentaries.update', commentary.id) }}">
                        {{ csrf_field() }}
                        <input type="hidden" name="_method" value="PUT">
                        
                        <div class="mb-3">
                            <label for="verification_level" class="form-label">Ellenőrzési szint</label>
                            <select class="form-select" id="verification_level" name="verification_level" required>
                                <option value="none" {% if commentary.verification_level == 'none' %}selected{% endif %}>none - Nincs ellenőrzés</option>
                                <option value="sanity" {% if commentary.verification_level == 'sanity' %}selected{% endif %}>sanity - Ésszerűségi ellenőrzés</option>
                                <option value="theology" {% if commentary.verification_level == 'theology' %}selected{% endif %}>theology - Teológiai ellenőrzés</option>
                            </select>
                            <div class="form-text">
                                Válassza ki a kommentár ellenőrzési szintjét. A "theology" a legmagasabb szintű ellenőrzést jelenti.
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-check-circle"></i> Ellenőrzési szint frissítése
                        </button>
                    </form>
                </div>
            </div>

            <!-- Actions -->
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Műveletek</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ route('editor.commentaries.index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Vissza
                        </a>
                        <form method="POST" action="{{ route('editor.commentaries.destroy', commentary.id) }}" onsubmit="return confirm('Biztosan törölni szeretné ezt a kommentárt?');">
                            {{ csrf_field() }}
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-trash"></i> Kommentár törlése
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Commentary text edit toggle
    const toggleEditTextBtn = document.getElementById('toggle-edit-text');
    const cancelEditTextBtn = document.getElementById('cancel-edit-text');
    const commentaryTextDisplay = document.getElementById('commentary-text-display');
    const commentaryTextEdit = document.getElementById('commentary-text-edit');
    
    if (toggleEditTextBtn) {
        toggleEditTextBtn.addEventListener('click', function() {
            commentaryTextDisplay.style.display = 'none';
            commentaryTextEdit.style.display = 'block';
            toggleEditTextBtn.style.display = 'none';
        });
    }
    
    if (cancelEditTextBtn) {
        cancelEditTextBtn.addEventListener('click', function() {
            commentaryTextDisplay.style.display = 'block';
            commentaryTextEdit.style.display = 'none';
            toggleEditTextBtn.style.display = 'block';
        });
    }
    
    // References edit toggle
    const toggleEditReferencesBtn = document.getElementById('toggle-edit-references');
    const cancelEditReferencesBtn = document.getElementById('cancel-edit-references');
    const referencesDisplay = document.getElementById('references-display');
    const referencesEdit = document.getElementById('references-edit');
    
    if (toggleEditReferencesBtn) {
        toggleEditReferencesBtn.addEventListener('click', function() {
            referencesDisplay.style.display = 'none';
            referencesEdit.style.display = 'block';
            toggleEditReferencesBtn.style.display = 'none';
        });
    }
    
    if (cancelEditReferencesBtn) {
        cancelEditReferencesBtn.addEventListener('click', function() {
            referencesDisplay.style.display = 'block';
            referencesEdit.style.display = 'none';
            toggleEditReferencesBtn.style.display = 'block';
        });
    }
    
    // Add new reference
    const addReferenceBtn = document.getElementById('add-reference');
    const referencesEditContainer = document.getElementById('references-edit-container');
    
    if (addReferenceBtn && referencesEditContainer) {
        addReferenceBtn.addEventListener('click', function() {
            const index = referencesEditContainer.children.length;
            const newReferenceHtml = `
                <div class="reference-edit-item mb-3 p-3 border rounded">
                    <div class="row">
                        <div class="col-md-5">
                            <label class="form-label">Hivatkozás</label>
                            <input type="text" class="form-control" name="references[${index}][ref]" value="" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Leírás / Indoklás</label>
                            <input type="text" class="form-control" name="references[${index}][reason]" value="">
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-danger btn-sm remove-reference" data-index="${index}">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `;
            
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = newReferenceHtml;
            referencesEditContainer.appendChild(tempDiv.firstElementChild);
            
            // Attach event listener to the new remove button
            const newRemoveBtn = referencesEditContainer.lastElementChild.querySelector('.remove-reference');
            if (newRemoveBtn) {
                newRemoveBtn.addEventListener('click', function() {
                    this.closest('.reference-edit-item').remove();
                    // Reindex remaining references
                    reindexReferences();
                });
            }
        });
    }
    
    // Remove reference buttons
    document.querySelectorAll('.remove-reference').forEach(btn => {
        btn.addEventListener('click', function() {
            this.closest('.reference-edit-item').remove();
            // Reindex remaining references
            reindexReferences();
        });
    });
    
    // Reindex references after removal
    function reindexReferences() {
        const referenceItems = referencesEditContainer.querySelectorAll('.reference-edit-item');
        referenceItems.forEach((item, index) => {
            // Update input names
            const refInput = item.querySelector('input[name*="[ref]"]');
            const reasonInput = item.querySelector('input[name*="[reason]"]');
            const removeBtn = item.querySelector('.remove-reference');
            
            if (refInput) {
                refInput.name = `references[${index}][ref]`;
            }
            if (reasonInput) {
                reasonInput.name = `references[${index}][reason]`;
            }
            if (removeBtn) {
                removeBtn.dataset.index = index;
            }
        });
    }
    
    // Form submission handling
    const commentaryTextForm = document.getElementById('commentary-text-form');
    const referencesForm = document.getElementById('references-form');
    
    if (commentaryTextForm) {
        commentaryTextForm.addEventListener('submit', function(e) {
            // Form will submit normally
        });
    }
    
    if (referencesForm) {
        referencesForm.addEventListener('submit', function(e) {
            // Form will submit normally
        });
    }
});
</script>

<style>
    .commentary-text-display,
    .source-text-display {
        line-height: 1.8;
        font-size: 1rem;
    }

    .commentary-text-display p,
    .source-text-display p {
        margin-bottom: 1rem;
    }

    .commentary-text-display h1,
    .commentary-text-display h2,
    .commentary-text-display h3,
    .commentary-text-display h4,
    .commentary-text-display h5,
    .commentary-text-display h6,
    .source-text-display h1,
    .source-text-display h2,
    .source-text-display h3,
    .source-text-display h4,
    .source-text-display h5,
    .source-text-display h6 {
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .commentary-text-display ul,
    .commentary-text-display ol,
    .source-text-display ul,
    .source-text-display ol {
        margin-bottom: 1rem;
        padding-left: 2rem;
    }

    .commentary-text-display li,
    .source-text-display li {
        margin-bottom: 0.5rem;
    }

    .commentary-text-display code,
    .source-text-display code {
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-family: 'Courier New', monospace;
    }

    .commentary-text-display blockquote,
    .source-text-display blockquote {
        border-left: 4px solid ;
        padding-left: 1rem;
        margin-left: 0;
        color: #666;
    }
    
    .reference-edit-item {
    }
</style>
{% endblock %}
