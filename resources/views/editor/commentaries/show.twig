{% extends 'layout.twig' %}

{% block pageHeader %}
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1>Kommentár szerkesztése</h1>
            <p class="text-muted">
                <span class="badge bg-primary">{{ commentary.translation.abbrev }}</span>
                <span class="badge bg-secondary">{{ book.abbrev }}</span>
            </p>
        </div>
        <a href="{{ route('editor.commentaries.index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Vissza a listához
        </a>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="commentary-editor">
    <div class="row">
        <div class="col-lg-8">
            <!-- Commentary Details -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Kommentár szövege</h5>
                </div>
                <div class="card-body">
                    <div class="commentary-text-display">
                        {% apply markdown_to_html %}
{{ commentaryData.commentary_text }}
                        {% endapply %}
                    </div>
                </div>
            </div>

            <!-- References Section -->
            {% if commentaryData.references and commentaryData.references|length > 0 %}
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Hivatkozások</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        {% for reference in commentaryData.references %}
                            <li class="mb-3">
                                <strong>{{ reference.ref }}</strong>
                                <p class="mb-0 text-muted small">{{ reference.reason }}</p>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endif %}

            <!-- Metadata -->
            {% if commentary.metadata %}
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Metaadatok</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        {% for key, value in commentary.metadata %}
                            <dt class="col-sm-3">{{ key }}</dt>
                            <dd class="col-sm-9">
                                {% if value is iterable %}
                                    <code>{{ value|json_encode }}</code>
                                {% else %}
                                    <code>{{ value }}</code>
                                {% endif %}
                            </dd>
                        {% endfor %}
                    </dl>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <!-- Sidebar Information -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Információ</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-6">Fordítás:</dt>
                        <dd class="col-sm-6">
                            <span class="badge bg-primary">{{ commentary.translation.abbrev }}</span>
                        </dd>

                        <dt class="col-sm-6">Könyv:</dt>
                        <dd class="col-sm-6">
                            <strong>{{ book.abbrev }}</strong>
                        </dd>

                        <dt class="col-sm-6">USX kód:</dt>
                        <dd class="col-sm-6">
                            <code>{{ commentary.usx_code }}</code>
                        </dd>

                        <dt class="col-sm-6">Versek:</dt>
                        <dd class="col-sm-6">
                            <small>{{ formattedRanges }}</small>
                        </dd>

                        <dt class="col-sm-6">Hossz:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.commentary_text|length }} karakter</small>
                        </dd>

                        <dt class="col-sm-6">Létrehozva:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.created_at.format('Y-m-d H:i:s') }}</small>
                        </dd>

                        <dt class="col-sm-6">Módosítva:</dt>
                        <dd class="col-sm-6">
                            <small>{{ commentary.updated_at.format('Y-m-d H:i:s') }}</small>
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Verse Ranges -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Versek</h5>
                </div>
                <div class="card-body">
                    {% if commentary.ranges.count() > 0 %}
                        <ul class="list-unstyled">
                            {% for range in commentary.ranges %}
                                <li class="mb-2">
                                    <span class="badge bg-info">
                                        {{ range.start_chapter }}:{{ range.start_verse }} - {{ range.end_chapter }}:{{ range.end_verse }}
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">Nincsenek versek definiálva.</p>
                    {% endif %}
                </div>
            </div>

            <!-- Actions -->
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Műveletek</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ route('editor.commentaries.index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Vissza
                        </a>
                        <form method="POST" action="{{ route('editor.commentaries.destroy', commentary.id) }}" onsubmit="return confirm('Biztosan törölni szeretné ezt a kommentárt?');">
                            {{ csrf_field() }}
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-trash"></i> Kommentár törlése
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .commentary-text-display {
        line-height: 1.8;
        font-size: 1rem;
        color: #333;
    }

    .commentary-text-display p {
        margin-bottom: 1rem;
    }

    .commentary-text-display h1,
    .commentary-text-display h2,
    .commentary-text-display h3,
    .commentary-text-display h4,
    .commentary-text-display h5,
    .commentary-text-display h6 {
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .commentary-text-display ul,
    .commentary-text-display ol {
        margin-bottom: 1rem;
        padding-left: 2rem;
    }

    .commentary-text-display li {
        margin-bottom: 0.5rem;
    }

    .commentary-text-display code {
        background-color: #f5f5f5;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-family: 'Courier New', monospace;
    }

    .commentary-text-display blockquote {
        border-left: 4px solid #ddd;
        padding-left: 1rem;
        margin-left: 0;
        color: #666;
    }
</style>
{% endblock %}
