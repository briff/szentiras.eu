{% extends 'layout.twig' %}

{% block pageHeader %}
<div class="page-header mb-4">
    <h1>Kommentárok szerkesztése</h1>
    <p class="text-muted">Generált AI kommentárok kezelése</p>
</div>
{% endblock %}

{% block script %}
<script>
(function() {
    const POLL_INTERVAL = 5000; // 5 seconds
    const STATUS_PENDING = 'pending';
    const STATUS_PROCESSING = 'processing';
    const STATUS_COMPLETED = 'completed';
    const STATUS_FAILED = 'failed';

    function getBadgeClass(status) {
        switch (status) {
            case STATUS_PENDING: return 'bg-warning';
            case STATUS_PROCESSING: return 'bg-info';
            case STATUS_COMPLETED: return 'bg-success';
            case STATUS_FAILED: return 'bg-danger';
            default: return 'bg-secondary';
        }
    }

    function updateRow(row, data) {
        // Update status attribute
        row.dataset.status = data.status;
        
        // Find the badge element (third column)
        const badge = row.querySelector('td:nth-child(3) .badge');
        if (badge) {
            badge.className = 'badge ' + getBadgeClass(data.status);
            badge.textContent = data.status;
        }

        // If status changed to completed or failed, stop polling for this row
        if (data.status === STATUS_COMPLETED || data.status === STATUS_FAILED) {
            row.dataset.polling = 'stopped';
            // Optionally show a small notification
            console.log('Commentary ' + row.dataset.commentaryId + ' finished with status ' + data.status);
        }
    }

    function pollRow(row) {
        const url = row.dataset.statusUrl;
        const commentaryId = row.dataset.commentaryId;
        
        fetch(url, {
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('HTTP error ' + response.status);
            }
            return response.json();
        })
        .then(data => {
            if (data.status !== row.dataset.status) {
                updateRow(row, data);
            }
        })
        .catch(error => {
            console.error('Failed to poll commentary ' + commentaryId, error);
        });
    }

    function startPolling() {
        const rows = document.querySelectorAll('tr[data-commentary-id]');
        rows.forEach(row => {
            const status = row.dataset.status;
            if (status === STATUS_PENDING || status === STATUS_PROCESSING) {
                // Poll immediately, then set interval
                pollRow(row);
                const intervalId = setInterval(() => {
                    if (row.dataset.polling === 'stopped') {
                        clearInterval(intervalId);
                        return;
                    }
                    pollRow(row);
                }, POLL_INTERVAL);
                row.dataset.intervalId = intervalId;
            }
        });
    }

    // Start polling when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startPolling);
    } else {
        startPolling();
    }
})();
</script>
{% endblock %}

{% block content %}
<div class="commentaries-editor">
    {% if commentaries.count() > 0 %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Fordítás</th>
                        <th>Könyv</th>
                        <th>Státusz</th>
                        <th>Versek</th>
                        <th>Létrehozva</th>
                        <th>Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commentary in commentaries %}
                    <tr data-commentary-id="{{ commentary.id }}" data-status="{{ commentary.status }}" data-status-url="{{ route('editor.commentaries.status', commentary.id) }}">
                        <td>
                            <span class="badge bg-primary">{{ commentary.translation.abbrev }}</span>
                        </td>
                        <td>
                            <strong>{{ commentary.usx_code }}</strong>
                        </td>
                        <td>
                            {% set statusBadgeClass = 'bg-secondary' %}
                            {% if commentary.status == 'pending' %}
                                {% set statusBadgeClass = 'bg-warning' %}
                            {% elseif commentary.status == 'processing' %}
                                {% set statusBadgeClass = 'bg-info' %}
                            {% elseif commentary.status == 'completed' %}
                                {% set statusBadgeClass = 'bg-success' %}
                            {% elseif commentary.status == 'failed' %}
                                {% set statusBadgeClass = 'bg-danger' %}
                            {% endif %}
                            <span class="badge {{ statusBadgeClass }}">{{ commentary.status }}</span>
                        </td>
                        <td>
                            <small class="text-muted">
                                {% set rangeStrings = [] %}
                                {% for range in commentary.ranges %}
                                    {% set rangeStrings = rangeStrings|merge([range.start_chapter ~ ':' ~ range.start_verse ~ '-' ~ range.end_chapter ~ ':' ~ range.end_verse]) %}
                                {% endfor %}
                                {{ rangeStrings|join(', ') }}
                            </small>
                        </td>
                        <td>
                            <small class="text-muted">{{ commentary.created_at.format('Y-m-d H:i') }}</small>
                        </td>
                        <td>
                            <a href="{{ route('editor.commentaries.show', commentary.id) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Megtekintés
                            </a>
                            <form method="POST" action="{{ route('editor.commentaries.destroy', commentary.id) }}" class="d-inline" onsubmit="return confirm('Biztosan törölni szeretné ezt a kommentárt?');">
                                {{ csrf_field() }}
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Törlés
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if commentaries.hasPages() %}
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                {% if commentaries.onFirstPage() %}
                    <li class="page-item disabled">
                        <span class="page-link">Előző</span>
                    </li>
                {% else %}
                    <li class="page-item">
                        <a class="page-link" href="{{ commentaries.previousPageUrl() }}">Előző</a>
                    </li>
                {% endif %}

                {% for page in commentaries.getUrlRange(1, commentaries.lastPage()) %}
                    {% if page == commentaries.currentPage() %}
                        <li class="page-item active">
                            <span class="page-link">{{ page }}</span>
                        </li>
                    {% else %}
                        <li class="page-item">
                            <a class="page-link" href="{{ commentaries.url(page) }}">{{ page }}</a>
                        </li>
                    {% endif %}
                {% endfor %}

                {% if commentaries.hasMorePages() %}
                    <li class="page-item">
                        <a class="page-link" href="{{ commentaries.nextPageUrl() }}">Következő</a>
                    </li>
                {% else %}
                    <li class="page-item disabled">
                        <span class="page-link">Következő</span>
                    </li>
                {% endif %}
            </ul>
        </nav>
        {% endif %}
    {% else %}
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>Nincs kommentár</strong>
            <p class="mb-0">Még nem lett generálva AI kommentár. Használja az <code>ai:generate-commentary</code> parancsot kommentárok létrehozásához.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
