<div class="card h-100 border-0" style="background-color: #f8f7f4;">
    <div class="card-body text-center">
        <i class="bi-translate display-4 mb-3" style="color: #7b9bb5;"></i>
        <h5 class="card-title" style="color: #4a5568;">Fordítás választás</h5>
        <p class="card-text mb-3" style="color: #718096;">Válassz egy fordítást a gyors olvasáshoz</p>
        
        <div class="mt-4 text-start">
            <div class="mb-3">
                <label class="form-label fw-semibold">Katolikus fordítások</label>
                <div class="list-group mb-2">
                    {% for translation in cathBibles|default([]) %}
                    <a href="/{{ translation.abbrev }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" style="background-color: #fdfcfb; border-color: #e8e3dd; color: #4a5568;">
                        <span>{{ translation.name }}</span>
                        <i class="bi-arrow-right" style="color: #a09890;"></i>
                    </a>
                    {% else %}
                    <div class="list-group-item" style="background-color: #fdfcfb; color: #a09890;">
                        Nincs elérhető katolikus fordítás
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Protestáns fordítások</label>
                <div class="list-group mb-2">
                    {% for translation in otherBibles|default([]) %}
                    <a href="/{{ translation.abbrev }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" style="background-color: #fdfcfb; border-color: #e8e3dd; color: #4a5568;">
                        <span>{{ translation.name }}</span>
                        <i class="bi-arrow-right" style="color: #a09890;"></i>
                    </a>
                    {% else %}
                    <div class="list-group-item" style="background-color: #fdfcfb; color: #a09890;">
                        Nincs elérhető protestáns fordítás
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Eredeti nyelv</label>
                <div class="list-group">
                        <a href="/GNT" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" style="background-color: #fdfcfb; border-color: #e8e3dd; color: #4a5568;">
                            <span>Görög Újszövetségi Szentírás</span>
                            <i class="bi-arrow-right" style="color: #a09890;"></i>
                        </a>
                    <!-- Add more non-Hungarian translations here if available -->
                </div>
            </div>

            <div class="mt-3">
                <div class="d-grid">
                    <a href="/forditasok" class="btn" style="color: #8b8fa8; border-color: #8b8fa8; background: transparent;">
                        <i class="bi-list me-1"></i> Összes fordítás megtekintése
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <div class="text-center">
                    <small style="color: #a09890;">
                        <i class="bi-info-circle me-1"></i>
                        Kattints a fordítás nevére a gyors elindításhoz
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>