<div class="card h-100">
    <div class="card-body text-center">
        <i class="bi-translate display-4 text-info mb-3"></i>
        <h5 class="card-title">Fordítás választás</h5>
        <p class="card-text text-muted mb-3">Válassz egy fordítást a gyors olvasáshoz</p>
        
        <div class="mt-4 text-start">
            <div class="mb-3">
                <label class="form-label fw-semibold">Katolikus fordítások</label>
                <div class="list-group mb-2">
                    {% for translation in cathBibles|default([]) %}
                    <a href="/{{ translation.abbrev }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>{{ translation.name }}</span>
                        <i class="bi-arrow-right text-muted"></i>
                    </a>
                    {% else %}
                    <div class="list-group-item text-muted">
                        Nincs elérhető katolikus fordítás
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Protestáns fordítások</label>
                <div class="list-group mb-2">
                    {% for translation in otherBibles|default([]) %}
                    <a href="/{{ translation.abbrev }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>{{ translation.name }}</span>
                        <i class="bi-arrow-right text-muted"></i>
                    </a>
                    {% else %}
                    <div class="list-group-item text-muted">
                        Nincs elérhető protestáns fordítás
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Egyéb fordítások</label>
                <div class="list-group">
                    <a href="/GNT" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>Görög Újszövetségi Szentírás</span>
                        <i class="bi-arrow-right text-muted"></i>
                    </a>
                    <!-- Add more non-Hungarian translations here if available -->
                </div>
            </div>

            <div class="mt-3">
                <div class="d-grid">
                    <a href="/forditasok" class="btn btn-outline-primary">
                        <i class="bi-list me-1"></i> Összes fordítás megtekintése
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <div class="text-center">
                    <small class="text-muted">
                        <i class="bi-info-circle me-1"></i>
                        Kattints a fordítás nevére a gyors elindításhoz
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>