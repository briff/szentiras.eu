{% extends "layout" %}

{% block pageHeader %}
    <div class="page-header">
        <h1><i class="bi bi-puzzle-fill"></i> Online memóriajáték</h1>
    </div>
{% endblock %}

{% block content %}
    <div class="container-fluid px-0">
        <div class="row">
            <div class="col-12">
                <p class="lead">Találjon párosító kártyákat bibliai versekből! Fordítsa fel a kártyákat és találja meg az összetartozó feleket.</p>
                
                {% if errors|length > 0 %}
                    <div class="alert alert-danger">
                        <h6><i class="bi bi-exclamation-triangle"></i> Hibák</h6>
                        <ul class="mb-0">
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if cards|length == 0 %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-gear"></i> Játék beállítások</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="/tools/memory-game-play" id="settingsForm">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="action" value="generate">
                            
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="translation_abbrev" class="form-label">
                                        <i class="bi bi-book"></i> Fordítás:
                                    </label>
                                    <select class="form-select" id="translation_abbrev" name="translation_abbrev" required>
                                        {% for translation in translations %}
                                            <option value="{{ translation.abbrev }}" 
                                                {{ translation.abbrev == selectedTranslation ? 'selected' : '' }}>
                                                {{ translation.name }} ({{ translation.abbrev }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                
                                <div class="col-md-4 mb-3">
                                    <label for="rows" class="form-label">
                                        <i class="bi bi-arrows-vertical"></i> Sorok száma:
                                    </label>
                                    <input type="number" class="form-control" id="rows" name="rows" 
                                           min="2" value="{{ rows }}" required>
                                    <small class="form-text text-muted">Legalább 2 sor</small>
                                </div>
                                
                                <div class="col-md-4 mb-3">
                                    <label for="cols" class="form-label">
                                        <i class="bi bi-arrows-horizontal"></i> Oszlopok száma:
                                    </label>
                                    <input type="number" class="form-control" id="cols" name="cols" 
                                           min="2" value="{{ cols }}" required>
                                    <small class="form-text text-muted">Legalább 2 oszlop</small>
                                </div>
                            </div>
                            
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> 
                                <strong>Fontos:</strong> A sorok és oszlopok szorzata páros számot kell adjon (pl. 2×3=6, 3×4=12, 4×4=16 stb.)
                            </div>
                            
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-play-fill"></i> Játék indítása
                            </button>
                        </form>
                    </div>
                </div>
                
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-question-circle"></i> Játékszabályok</h5>
                    </div>
                    <div class="card-body">
                        <ol>
                            <li>Állítsa be a kívánt tábla méretet (sorok × oszlopok)</li>
                            <li>Válassza ki a fordítást</li>
                            <li>Indítsa el a játékot</li>
                            <li>Kattintson két kártyára, hogy felfordítsa őket</li>
                            <li>Ha a kártyákon lévő szövegek összetartoznak (egy vers két fele), maradnak felfordítva</li>
                            <li>Ha nem tartoznak össze, visszafordulnak</li>
                            <li>Találja meg az összes párt a győzelemhez!</li>
                        </ol>
                    </div>
                </div>
                {% else %}
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-controller"></i> Memóriajáték</h5>
                            <div>
                                <span class="badge bg-light text-dark me-2">
                                    <i class="bi bi-clock"></i> <span id="timer">00:00</span>
                                </span>
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-arrow-repeat"></i> Lépések: <span id="moves">0</span>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="game-board" class="memory-game-board" style="grid-template-columns: repeat({{ cols }}, 1fr);">
                            <!-- Cards will be inserted here by JavaScript -->
                        </div>
                        
                        <div class="mt-3">
                            <a href="/tools/memory-game-play" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Új játék indítása
                            </a>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <style>
        .memory-game-board {
            display: grid;
            gap: 10px;
            margin: 20px auto;
            max-width: 800px;
        }
        
        .memory-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
            cursor: pointer;
            min-height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
            position: relative;
            transition: transform 0.3s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .memory-card:hover:not(.flipped):not(.matched) {
            transform: scale(1.05);
        }
        
        .memory-card.flipped,
        .memory-card.matched {
            background: white;
            border: 2px solid #667eea;
        }
        
        .memory-card.matched {
            background: #d4edda;
            border-color: #28a745;
            cursor: default;
        }
        
        .card-front {
            display: none;
            text-align: center;
            font-size: 0.95rem;
            line-height: 1.4;
            color: #333;
            word-wrap: break-word;
        }
        
        .card-back {
            color: white;
            font-size: 3rem;
            font-weight: bold;
        }
        
        .memory-card.flipped .card-front,
        .memory-card.matched .card-front {
            display: block;
        }
        
        .memory-card.flipped .card-back,
        .memory-card.matched .card-back {
            display: none;
        }
        
        [data-theme="dark"] .memory-card.flipped,
        [data-theme="dark"] .memory-card.matched {
            background: #2d3748;
            color: #e2e8f0;
        }
        
        [data-theme="dark"] .card-front {
            color: #e2e8f0;
        }
        
        #victory-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }
        
        #victory-modal.show {
            display: flex;
        }
        
        .victory-content {
            background: white;
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            max-width: 500px;
            animation: bounceIn 0.5s;
        }
        
        [data-theme="dark"] .victory-content {
            background: #2d3748;
            color: #e2e8f0;
        }
        
        @keyframes bounceIn {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.05); }
            70% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>

    {% if cards|length > 0 %}
    <div id="victory-modal">
        <div class="victory-content">
            <h2 class="text-success mb-3">
                <i class="bi bi-trophy-fill"></i> Gratulálunk!
            </h2>
            <p class="lead">Sikeresen megtalálta az összes párt!</p>
            <p>
                <strong>Idő:</strong> <span id="final-time"></span><br>
                <strong>Lépések:</strong> <span id="final-moves"></span>
            </p>
            <a href="/tools/memory-game-play" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-arrow-clockwise"></i> Új játék
            </a>
        </div>
    </div>

    <script>
        const cards = {{ cards|json_encode|raw }};
        let gameCards = [];
        let flippedCards = [];
        let matchedPairs = 0;
        let moves = 0;
        let startTime = null;
        let timerInterval = null;
        
        // Prepare cards array (each pair becomes two cards)
        cards.forEach(pair => {
            gameCards.push({
                id: `${pair.pairId}-1`,
                pairId: pair.pairId,
                text: pair.firstHalf
            });
            gameCards.push({
                id: `${pair.pairId}-2`,
                pairId: pair.pairId,
                text: pair.secondHalf
            });
        });
        
        // Shuffle cards
        gameCards.sort(() => Math.random() - 0.5);
        
        // Initialize game board
        const gameBoard = document.getElementById('game-board');
        gameCards.forEach(card => {
            const cardElement = document.createElement('div');
            cardElement.className = 'memory-card';
            cardElement.dataset.cardId = card.id;
            cardElement.dataset.pairId = card.pairId;
            cardElement.innerHTML = `
                <div class="card-back">?</div>
                <div class="card-front">${card.text}</div>
            `;
            cardElement.addEventListener('click', () => flipCard(cardElement));
            gameBoard.appendChild(cardElement);
        });
        
        function flipCard(cardElement) {
            if (cardElement.classList.contains('flipped') || 
                cardElement.classList.contains('matched') ||
                flippedCards.length >= 2) {
                return;
            }
            
            if (!startTime) {
                startTime = Date.now();
                timerInterval = setInterval(updateTimer, 1000);
            }
            
            cardElement.classList.add('flipped');
            flippedCards.push(cardElement);
            
            if (flippedCards.length === 2) {
                moves++;
                document.getElementById('moves').textContent = moves;
                
                setTimeout(checkMatch, 1000);
            }
        }
        
        function checkMatch() {
            const [card1, card2] = flippedCards;
            const pairId1 = card1.dataset.pairId;
            const pairId2 = card2.dataset.pairId;
            
            if (pairId1 === pairId2) {
                card1.classList.add('matched');
                card2.classList.add('matched');
                matchedPairs++;
                
                if (matchedPairs === cards.length) {
                    endGame();
                }
            } else {
                card1.classList.remove('flipped');
                card2.classList.remove('flipped');
            }
            
            flippedCards = [];
        }
        
        function updateTimer() {
            if (!startTime) return;
            
            const elapsed = Math.floor((Date.now() - startTime) / 1000);
            const minutes = Math.floor(elapsed / 60);
            const seconds = elapsed % 60;
            document.getElementById('timer').textContent = 
                `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
        }
        
        function endGame() {
            clearInterval(timerInterval);
            document.getElementById('final-time').textContent = document.getElementById('timer').textContent;
            document.getElementById('final-moves').textContent = moves;
            document.getElementById('victory-modal').classList.add('show');
        }
    </script>
    {% endif %}
{% endblock %}
