{% extends "layout" %}

{% block pageHeader %}
    <div class="page-header">
        <h1>Eszközök</h1>
    </div>
{% endblock %}

{% block content %}
    <div class="container-fluid px-0">
        <p>Különböző eszközök és segédletek a Szentírás tanulmányozásához.</p>
        
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-puzzle"></i> Memóriajáték készítő</h5>
                        <p class="card-text">Készítsen memóriajátékot bibliai igékből. Adjon meg igehelyeket, és az eszköz automatikusan létrehozza a játékkártyákat.</p>
                        <a href="/tools/memorygame" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-puzzle-fill"></i> Online memóriajáték</h5>
                        <p class="card-text">Játsszon memóriajátékot bibliai versekkel közvetlenül a böngészőben! Állítsa be a tábla méretét, és találja meg az összetartozó versrészleteket.</p>
                        <a href="/tools/memory-game-play" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-book-half"></i> Találd ki a könyvet</h5>
                        <p class="card-text">Találja ki, melyik bibliai könyvből származik a megjelenített igeszakasz! Minden tippnél visszajelzést kap a szövetségről, szekcióról és kezdőbetűről.</p>
                        <a href="/tools/guessbook" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-fonts"></i> Találd ki a hiányzó szót</h5>
                        <p class="card-text">Találd ki, melyik szó hiányzik a bibliai idézetből! Wordle-szerű játék: a színek jelzik, mennyire vagy közel a megoldáshoz. 6 próbálkozásod van!</p>
                        <a href="/tools/guess-word" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-shuffle"></i> Verskirakó játék</h5>
                        <p class="card-text">Rakd össze helyes sorrendbe egy bibliai vers összekevert szavait! Kattints a szavakra, hogy összeállítsd a verset.</p>
                        <a href="/tools/verse-scramble" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-text-paragraph"></i> Szó a következő versből</h5>
                        <p class="card-text">Találd ki, melyik szó szerepel a következő versben! Olvasd el a verset, nézd meg a 4 lehetőséget, és találd meg az egyetlen szót, ami a következő versben található.</p>
                        <a href="/tools/word-from-next-verse" class="btn btn-primary">Megnyitás</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
