{% extends 'layout.twig' %}

{% block pageHeader %}
<div class="page-header mb-4">
    <h1>Saját API kulcsaim</h1>
    <p class="text-muted">API kulcsok létrehozása és kezelése a szentiras.eu API eléréséhez</p>
</div>
{% endblock %}

{% block content %}
<div class="api-keys">
    {% if session('success') %}
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> {{ session('success') }}
        </div>
    {% endif %}

    {% if errors.any() %}
        <div class="alert alert-danger">
            {% for error in errors.all() %}
                <div>{{ error }}</div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            {% if keys.count() < maxKeys %}
                <a href="{{ route('profile.apiKeys.create') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Új API kulcs
                </a>
            {% else %}
                <button class="btn btn-primary" disabled title="Elérted a maximális kulcsszámot">
                    <i class="bi bi-plus-circle"></i> Új API kulcs
                </button>
            {% endif %}
        </div>
        <div class="text-muted">
            <small>API kulcsok: {{ keys.count() }} / {{ maxKeys }}</small>
        </div>
    </div>

    {% if keys.count() > 0 %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Név</th>
                        <th>Előtag</th>
                        <th>Státusz</th>
                        <th>Utoljára használva</th>
                        <th>Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    {% for key in keys %}
                    <tr>
                        <td>
                            <strong>{{ key.name }}</strong>
                            {% if key.description %}
                                <br><small class="text-muted">{{ key.description }}</small>
                            {% endif %}
                        </td>
                        <td>
                            <code class="text-muted">{{ key.key_prefix }}</code>
                        </td>
                        <td>
                            {% if key.enabled %}
                                <span class="badge bg-success">Aktív</span>
                            {% else %}
                                <span class="badge bg-danger">Letiltva</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if key.last_used_at %}
                                {{ key.last_used_at|date('Y-m-d H:i') }}
                                <br><small class="text-muted">használatok: {{ key.usage_count }}</small>
                            {% else %}
                                <span class="text-muted">még nem</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ route('profile.apiKeys.show', key.id) }}" class="btn btn-outline-primary" title="Részletek">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form action="{{ route('profile.apiKeys.destroy', key.id) }}" method="POST" class="d-inline" onsubmit="return confirm('Biztosan törölni szeretnéd ezt az API kulcsot?');">
                                    {{ csrf_field() }}
                                    {{ method_field('DELETE') }}
                                    <button type="submit" class="btn btn-outline-danger" title="Törlés">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Még nincs API kulcsod. Hozz létre egyet a fenti gombbal.
        </div>
    {% endif %}

    <div class="mt-4">
        <a href="{{ url('/profile') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Vissza a profilhoz
        </a>
    </div>
</div>
{% endblock %}
