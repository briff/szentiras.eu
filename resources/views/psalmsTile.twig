<div class="card h-100">
    <div class="card-body text-center">
        <i class="bi-music-note-beamed display-4 text-warning mb-3"></i>
        <h5 class="card-title">Zsoltárok</h5>
        <p class="card-text text-muted mb-3">150 zsoltár imádságokban, dicsőítésekben és bánatban</p>
        
        <div class="mt-4 text-start">
            <div class="mb-3">
                <div class="row g-2">
                    <div class="col-6">
                        <a href="/Zsolt1" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-1-circle me-1"></i> 1. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt23" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-2-circle me-1"></i> 23. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt51" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-3-circle me-1"></i> 51. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt91" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-4-circle me-1"></i> 91. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt100" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-5-circle me-1"></i> 100. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt121" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-6-circle me-1"></i> 121. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt139" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-7-circle me-1"></i> 139. zsoltár
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/Zsolt150" class="btn btn-outline-warning w-100 text-dark">
                            <i class="bi-8-circle me-1"></i> 150. zsoltár
                        </a>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Gyors keresés zsoltár szerint</label>
                <div class="input-group">
                    <input type="number" class="form-control" id="psalmNumberInput" placeholder="1-150" min="1" max="150" value="1">
                    <button class="btn btn-warning" id="goToPsalmButton" type="button">
                        <i class="bi-arrow-right"></i> Ugrás
                    </button>
                </div>
            </div>

            <div class="accordion mb-3" id="psalmsCategoriesAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePsalmsCategories" aria-expanded="false" aria-controls="collapsePsalmsCategories">
                            <i class="bi-tags me-2"></i> Zsoltárok kategóriák szerint
                        </button>
                    </h2>
                    <div id="collapsePsalmsCategories" class="accordion-collapse collapse" data-bs-parent="#psalmsCategoriesAccordion">
                        <div class="accordion-body p-0">
                            <div class="list-group list-group-flush">
                                <a href="/Zsolt1" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Boldogság (1-2)</span>
                                    <small class="text-muted">2 zsoltár</small>
                                </a>
                                <a href="/Zsolt3" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Könyörgés (3-41)</span>
                                    <small class="text-muted">39 zsoltár</small>
                                </a>
                                <a href="/Zsolt42" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Válasz (42-72)</span>
                                    <small class="text-muted">31 zsoltár</small>
                                </a>
                                <a href="/Zsolt73" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Bizonytalanság (73-89)</span>
                                    <small class="text-muted">17 zsoltár</small>
                                </a>
                                <a href="/Zsolt90" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Királyság (90-106)</span>
                                    <small class="text-muted">17 zsoltár</small>
                                </a>
                                <a href="/Zsolt107" class="list-group-item list-group-item-action d-flex justify-content-between">
                                    <span>Hálaadás (107-150)</span>
                                    <small class="text-muted">44 zsoltár</small>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <div class="d-grid gap-2">
                    <a href="/Zsolt1" class="btn btn-warning text-dark">
                        <i class="bi-play-circle me-1"></i> Olvasás kezdése
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const psalmInput = document.getElementById('psalmNumberInput');
    const goToPsalmButton = document.getElementById('goToPsalmButton');
    
    if (psalmInput && goToPsalmButton) {
        goToPsalmButton.addEventListener('click', function() {
            const psalmNumber = parseInt(psalmInput.value);
            if (psalmNumber >= 1 && psalmNumber <= 150) {
                window.location.href = '/Zsolt' + psalmNumber;
            } else {
                alert('Kérlek adj meg egy 1 és 150 közötti számot!');
            }
        });
        
        // Also allow Enter key in the input
        psalmInput.addEventListener('keyup', function(event) {
            if (event.key === 'Enter') {
                goToPsalmButton.click();
            }
        });
    }
});
</script>