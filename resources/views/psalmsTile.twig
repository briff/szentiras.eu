<div class="card h-100 border-0" style="background-color: #f8f7f4;">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <i class="bi-heart-pulse display-6 me-3" style="color: #b08d6a;"></i>
            <div>
                <h5 class="card-title mb-1" style="color: #4a5568;">Zsoltárok</h5>                
            </div>
        </div>

        <div class="mb-4 pt-3 border-top" style="border-color: #e8e3dd !important;">
            <div class="input-group input-group-sm">
                <input type="number" class="form-control" id="psalmNumberInput" placeholder="1-150" min="1" max="150" style="border-color: #d4cfc9; background-color: #fdfcfb;">
                <button class="btn" id="goToPsalmButton" type="button" style="color: #fff; background-color: #b08d6a; border-color: #b08d6a;">
                    <i class="bi-arrow-right"></i> Ugrás
                </button>
            </div>
        </div>

        <!-- Category Selection - Mobile Optimized -->
        <div class="mb-4">
            <div class="row g-2" id="psalmCategories">
                <!-- Category 1: Fear/Anxiety -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="fear" style="color: #5a7a6a; border-color: #a8c4b4; background-color: #f0f5f2;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🌿</span>
                            <span class="fw-semibold">Amikor félek</span>
                            <small class="mt-1" style="color: #8aaa9a;">6 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 2: Repentance -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="repentance" style="color: #6b6080; border-color: #b8aed0; background-color: #f3f1f8;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🙏</span>
                            <span class="fw-semibold">Bűnbánat</span>
                            <small class="mt-1" style="color: #9b90b0;">6 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 3: Gratitude -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="gratitude" style="color: #7a6a50; border-color: #c8b898; background-color: #f7f4ef;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🌅</span>
                            <span class="fw-semibold">Hála</span>
                            <small class="mt-1" style="color: #aa9878;">7 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 4: Trust/Strength -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="trust" style="color: #4a6880; border-color: #98b8d0; background-color: #f0f4f8;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🛡</span>
                            <span class="fw-semibold">Bizalom</span>
                            <small class="mt-1" style="color: #7a98b0;">5 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 5: Praise -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="praise" style="color: #806050; border-color: #d0b0a0; background-color: #f8f2ef;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">👑</span>
                            <span class="fw-semibold">Dicsőítés</span>
                            <small class="mt-1" style="color: #b09080;">8 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 6: Suffering -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="suffering" style="color: #606878; border-color: #b0b8c8; background-color: #f2f3f6;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">😢</span>
                            <span class="fw-semibold">Szenvedés</span>
                            <small class="mt-1" style="color: #9098a8;">6 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 7: Guidance -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="guidance" style="color: #5a6870; border-color: #a8b8c0; background-color: #f0f4f5;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🧭</span>
                            <span class="fw-semibold">Útmutatás</span>
                            <small class="mt-1" style="color: #8a98a0;">7 zsoltár</small>
                        </div>
                    </button>
                </div>
                
                <!-- Category 8: Evening/Travel -->
<div class="col-6 col-xl-4">
                    <button class="btn w-100 h-100 py-3 category-btn" data-category="evening" style="color: #504858; border-color: #a898b0; background-color: #f3f1f5;">
                        <div class="d-flex flex-column align-items-center">
                            <span class="fs-4 mb-1">🏔</span>
                            <span class="fw-semibold">Esti imák</span>
                            <small class="mt-1" style="color: #807888;">6 zsoltár</small>
                        </div>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Selected Category Psalms (Initially hidden) -->
        <div id="psalmsContainer" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0" id="categoryTitle">Kiválasztott kategória</h6>
                <button class="btn btn-sm" id="backToCategories" style="color: #6b6560; border-color: #d4cfc9; background-color: #ede9e4;">
                    <i class="bi-arrow-left me-1"></i> Vissza
                </button>
            </div>
            
            <div class="row g-2" id="psalmsGrid">
                <!-- Psalms will be dynamically loaded here -->
            </div>
        </div>
            <div class="mt-3">
                <div class="d-grid gap-2">
                    <a href="/Zsolt1" class="btn" style="color: #fff; background-color: #8b8fa8; border-color: #8b8fa8;">
                        <i class="bi-play-circle me-1"></i>Olvasás
                    </a>
                </div>
            </div>

    </div>

</div>

<style>
@keyframes fadeOut {
    from {
        opacity: 1;
        transform: translateY(0);
    }
    to {
        opacity: 0;
        transform: translateY(10px);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideOutLeft {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(-20px);
    }
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.category-btn {
    transition: all 0.2s ease;
    min-height: 85px;
    border-width: 1px;
    border-radius: 12px;
    font-size: 0.9rem;
}
.category-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    filter: brightness(0.97);
}
.category-btn.active {
    border-width: 2px;
    font-weight: bold;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

#psalmCategories.fade-out {
    animation: slideOutLeft 0.4s ease forwards;
}

#psalmsContainer.fade-in {
    animation: slideInRight 0.4s ease forwards;
}

#psalmsContainer.fade-out {
    animation: slideOutLeft 0.4s ease forwards;
}

#psalmCategories.fade-in {
    animation: slideInRight 0.4s ease forwards;
}

.psalm-btn {
    padding: 0.75rem 0.5rem;
    text-align: center;
    border-radius: 10px;
    border: 1px solid #e8e3dd;
    background-color: #fdfcfb;
    transition: all 0.2s ease;
}
.psalm-btn:hover {
    background-color: #f0ede8;
    border-color: #c8c4be;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.06);
}
.psalm-motto {
    font-size: 0.75rem;
    line-height: 1.2;
    color: #718096;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-style: italic;
}
#categoryTitle {
    font-weight: 600;
    color: #4a5568;
    padding: 0.5rem 0;
    border-bottom: 2px solid #e8e3dd;
}
@media (max-width: 768px) {
    .category-btn {
        min-height: 85px;
        padding: 0.5rem 0.25rem !important;
        border-radius: 10px;
    }
    .category-btn .fs-4 {
        font-size: 1.25rem !important;
        margin-bottom: 0.25rem !important;
    }
    .category-btn .fw-semibold {
        font-size: 0.8rem;
        line-height: 1.1;
    }
    .category-btn small {
        font-size: 0.7rem;
    }
    .psalm-btn {
        padding: 0.5rem 0.25rem;
    }
    .psalm-motto {
        font-size: 0.7rem;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Psalm data by category
    const psalmData = {
        fear: {
            title: "🌿 Amikor félek vagy szorongok",
            psalms: [
                { number: 23, motto: "Az Úr pásztorként vezet a legsötétebb völgyben is." },
                { number: 27, motto: "Nem kell félnem, mert az Úr az erősségem." },
                { number: 46, motto: "Isten a menedékünk, még ha megrendül is a világ." },
                { number: 56, motto: "Amikor félek, Istenben bízom." },
                { number: 91, motto: "A Magasságos oltalma alatt biztonságban vagyok." },
                { number: 121, motto: "Segítségem az Úrtól jön, aki az eget és földet alkotta." }
            ]
        },
        repentance: {
            title: "🙏 Amikor bűnbánatra van szükségem",
            psalms: [
                { number: 6, motto: "A szenvedő ember irgalomért kiált." },
                { number: 32, motto: "Boldog, akinek bűne megbocsáttatott." },
                { number: 38, motto: "A bűn súlya alatt Istenhez fordulok." },
                { number: 51, motto: "Tiszta szívet kér az, aki elesett." },
                { number: 130, motto: "A mélységből is meghall Isten." },
                { number: 143, motto: "Isten kegyelmére szorulok, nem a saját igazságomra." }
            ]
        },
        gratitude: {
            title: "🌅 Amikor hálás vagyok",
            psalms: [
                { number: 30, motto: "A sírás örömre fordul." },
                { number: 34, motto: "Áldom az Urat minden időben." },
                { number: 65, motto: "Isten bőséggel és áldással koronázza meg az évet." },
                { number: 103, motto: "Ne feledd el, mennyi jót tett veled az Úr." },
                { number: 107, motto: "Adjanak hálát az Úr szeretetéért és csodáiért." },
                { number: 116, motto: "Szeretem az Urat, mert meghallgatta imámat." },
                { number: 118, motto: "Az Úr szeretete örökké tart." }
            ]
        },
        trust: {
            title: "🛡 Amikor bizalomra és megerősítésre vágyom",
            psalms: [
                { number: 16, motto: "Isten az örökségem és biztos részem." },
                { number: 62, motto: "Lelkem csendben Istenre vár." },
                { number: 91, motto: "Az Úr a menedékem és váram." },
                { number: 125, motto: "Aki az Úrban bízik, rendíthetetlen." },
                { number: 131, motto: "Lelkem elcsendesedett, mint az anyja mellett nyugvó gyermek." }
            ]
        },
        praise: {
            title: "👑 Amikor dicsőíteni szeretném Istent",
            psalms: [
                { number: 8, motto: "Mily felséges az Úr neve az egész földön!" },
                { number: 19, motto: "Az egek hirdetik Isten dicsőségét." },
                { number: 29, motto: "Az Úr hangja erő és fenség." },
                { number: 95, motto: "Jöjjetek, örvendezzünk az Úrnak!" },
                { number: 96, motto: "Hirdessétek dicsőségét a népek között!" },
                { number: 100, motto: "Szolgáljatok az Úrnak örömmel!" },
                { number: 145, motto: "Az Úr nagy és igen dicséretes." },
                { number: 150, motto: "Mindent, ami él, dicsérje az Urat!" }
            ]
        },
        suffering: {
            title: "😢 Amikor szenvedek vagy nem értem, mi történik",
            psalms: [
                { number: 3, motto: "Sok ellenség közt is Istenhez kiáltok." },
                { number: 13, motto: "Meddig feledkezel meg rólam, Uram?" },
                { number: 22, motto: "A szenvedés mélyéről Istenhez kiáltok." },
                { number: 42, motto: "Miért csüggedsz el, lelkem? Bízz Istenben!" },
                { number: 69, motto: "Elborítanak a vizek, mégis Istenhez fordulok." },
                { number: 88, motto: "A legsötétebb panasz is imádság lehet." }
            ]
        },
        guidance: {
            title: "🧭 Amikor útmutatást és bölcsességet keresek",
            psalms: [
                { number: 1, motto: "Az boldog, aki Isten útján jár." },
                { number: 25, motto: "Taníts meg utaidra, Uram!" },
                { number: 37, motto: "Ne irigykedj a gonoszokra; bízz az Úrban." },
                { number: 73, motto: "Isten jelenlétében értem meg az élet titkát." },
                { number: 119, motto: "Isten igéje világosság az utamon." },
                { number: 127, motto: "Hiába építünk, ha az Úr nem építi." },
                { number: 128, motto: "Áldott az, aki az Urat féli." }
            ]
        },
        evening: {
            title: "🏔 Esti, utazó és zarándok imák",
            psalms: [
                { number: 4, motto: "Békességben fekszem le, mert az Úr vigyáz rám." },
                { number: 23, motto: "Az Úr vezet egész életemen át." },
                { number: 84, motto: "Boldog, aki Isten házába vágyik." },
                { number: 91, motto: "Isten oltalmaz minden úton." },
                { number: 121, motto: "Őriz az Úr jártomban-keltemben." },
                { number: 134, motto: "Áldjátok az Urat éjszaka is!" }
            ]
        }
    };

    // Category selection
    const categoryButtons = document.querySelectorAll('.category-btn');
    const categoriesContainer = document.getElementById('psalmCategories');
    const psalmsContainer = document.getElementById('psalmsContainer');
    const psalmsGrid = document.getElementById('psalmsGrid');
    const categoryTitle = document.getElementById('categoryTitle');
    const backToCategories = document.getElementById('backToCategories');
    
    // Quick psalm search elements
    const psalmInput = document.getElementById('psalmNumberInput');
    const goToPsalmButton = document.getElementById('goToPsalmButton');
    
    // Handle category selection
    categoryButtons.forEach(button => {
        button.addEventListener('click', function() {
            const category = this.dataset.category;
            
            // Update active state
            categoryButtons.forEach(btn => btn.classList.remove('active'));
            this.classList.add('active');
            
            // Store last selected category in session storage
            sessionStorage.setItem('lastPsalmCategory', category);
            
            // Animate transition
            categoriesContainer.classList.add('fade-out');
            
            // Show psalms after animation starts
            setTimeout(() => {
                showPsalms(category);
            }, 200);
        });
    });
    
    // Back to categories
    backToCategories.addEventListener('click', function() {
        psalmsContainer.classList.add('fade-out');
        
        setTimeout(() => {
            categoriesContainer.classList.remove('d-none');
            psalmsContainer.classList.add('d-none');
            categoriesContainer.classList.remove('fade-out');
            categoriesContainer.classList.add('fade-in');
            
            // Remove animation classes after animation completes
            setTimeout(() => {
                categoriesContainer.classList.remove('fade-in');
            }, 400);
        }, 200);
    });
    
    // Quick psalm search
    if (psalmInput && goToPsalmButton) {
        goToPsalmButton.addEventListener('click', function() {
            const psalmNumber = parseInt(psalmInput.value);
            if (psalmNumber >= 1 && psalmNumber <= 150) {
                window.location.href = '/Zsolt' + psalmNumber;
            } else {
                alert('Kérlek adj meg egy 1 és 150 közötti számot!');
            }
        });
        
        // Also allow Enter key in the input
        psalmInput.addEventListener('keyup', function(event) {
            if (event.key === 'Enter') {
                goToPsalmButton.click();
            }
        });
    }
    
    // Check if there's a last selected category (for future enhancements)
    const lastCategory = sessionStorage.getItem('lastPsalmCategory');
    if (lastCategory && psalmData[lastCategory]) {
        // Optional: Auto-select last category on page load
        // showPsalms(lastCategory);
    }
    
    // Show psalms for selected category
    function showPsalms(category) {
        const data = psalmData[category];
        if (!data) return;
        
        // Update title
        categoryTitle.textContent = data.title;
        
        // Clear previous psalms
        psalmsGrid.innerHTML = '';
        
        // Add psalm buttons
        data.psalms.forEach(psalm => {
            const col = document.createElement('div');
            col.className = 'col-6 ';
            
            const button = document.createElement('a');
            button.href = `/Zsolt${psalm.number}`;
            button.className = 'btn w-100 h-100 psalm-btn d-flex flex-column justify-content-center';
            button.innerHTML = `
                <span class="d-flex flex-row align-items-start mb-1 w-100">
                    <span class="fs-6 fw-bold me-2 flex-shrink-0" style="min-width:1.8em; color: #8b8fa8;">${psalm.number}</span>
                    <span class="psalm-motto text-wrap flex-grow-1" style="white-space:normal;-webkit-line-clamp:unset;overflow:visible;">${psalm.motto}</span>
                </span>
            `;
            
            col.appendChild(button);
            psalmsGrid.appendChild(col);
        });
        
        // Switch views with animation
        categoriesContainer.classList.add('d-none');
        psalmsContainer.classList.remove('d-none');
        psalmsContainer.classList.remove('fade-out');
        psalmsContainer.classList.add('fade-in');
        
        // Remove animation class after animation completes
        setTimeout(() => {
            psalmsContainer.classList.remove('fade-in');
        }, 400);
    }
});
</script>
