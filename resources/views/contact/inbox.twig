{% extends 'layout' %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 mb-0">
                    <i class="bi bi-inbox"></i> Üzeneteim
                </h2>
                <div>
                    <a href="{{ route('contact.form') }}" class="btn btn-primary">
                        <i class="bi bi-envelope-plus"></i> Új üzenet
                    </a>
                </div>
            </div>

            {% if messages.total == 0 %}
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">Nincsenek üzenetei</h5>
                        <p class="text-muted">Még nem kapott választ a szerkesztőktől.</p>
                        <a href="{{ route('contact.form') }}" class="btn btn-outline-primary">Üzenet küldése</a>
                    </div>
                </div>
            {% else %}
                <div class="list-group">
                    {% for msg in messages %}
                        <a href="{{ route('contact.thread', msg.id) }}"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">
                                    {% if msg.sender %}
                                        <span class="badge bg-secondary me-2">Szerkesztő</span>
                                    {% else %}
                                        <span class="badge bg-light text-dark me-2">Ön</span>
                                    {% endif %}
                                    {{ msg.message|slice(0, 100) }}{% if msg.message|length > 100 %}…{% endif %}
                                </div>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> {{ msg.created_at|date('Y. m. d. H:i') }}
                                </small>
                            </div>
                            <div>
                                {% if not msg.is_read %}
                                    <span class="badge bg-danger rounded-pill">Új</span>
                                {% endif %}
                                {% if msg.replies.count > 0 %}
                                    <span class="badge bg-info rounded-pill">{{ msg.replies.count }} válasz</span>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>

                {% if messages.lastPage > 1 %}
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            {% if messages.currentPage > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ messages.previousPageUrl }}">Előző</a>
                                </li>
                            {% endif %}
                            {% for page in 1..messages.lastPage %}
                                <li class="page-item {{ page == messages.currentPage ? 'active' }}">
                                    <a class="page-link" href="{{ messages.url(page) }}">{{ page }}</a>
                                </li>
                            {% endfor %}
                            {% if messages.currentPage < messages.lastPage %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ messages.nextPageUrl }}">Következő</a>
                                </li>
                            {% endif %}
                        </ul>
                    </nav>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}