        <span class="navbar-toggler-icon"></span>
    </button>
        <!-- Collect the nav links, forms, and other content for toggling -->
        <div class="collapse navbar-collapse" id="navbar">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Fordítások<span class="caret"></span></a>
                    <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                        <!--a class="dropdown-item" href="/KNB">Káldi-Neovulgáta (KNB)</a-->
                        <a class="dropdown-item" href="/SZIT">Szent István Társulati Biblia (SZIT)</a>
                        <a class="dropdown-item" href="/BD">Békés-Dalos Újszövetségi Szentírás (BD)</a></a>
                        <a class="dropdown-item" href="/STL">Simon Tamás László Újszövetség-fordítása (STL)</a>
                        <div class="dropdown-divider"></div>
                        <!--a class="dropdown-item" href="/RUF">Magyar Bibliatársulat Újfordítású Bibliája 2014 (RUF)</a-->
                        <a class="dropdown-item" href="/KG">Károli Gáspár revideált fordítása (KG)</a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" href="http://ujszov.hu" class="" rel="external" target="_new">
                            Görög újszövetségi honlap {{ externalIcon }}</a>
                        <div class="dropdown-divider"></div>                 
                        <a class="dropdown-item" href="/forditasok">Ismertetés a fordításokról</a>
                      </div>
                <li class="nav-item"><a class="nav-link" href="/tervek">Olvasási tervek</a></li>
                <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Kapcsolódó honlapok<span class="caret"></span></a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="https://szentjozsefhackathon.github.io/napi-lelki-batyu/naptar.html" target="_new">Katolikus igenaptár {{ externalIcon }}</a>
                        <a class="dropdown-item" href="https://lh.kbs.sk/cgi-bin/l.cgi?qt=pdnes&j=hu">Zsolozsma {{ externalIcon }}</a>
                        <a class="dropdown-item" href="https://szentiras.hu/" target="_new">Szent Jeromos Katolikus Bibliatársulat {{ externalIcon }}</a>
                    </div>
                </li>
                <li class="nav-item"><a class="nav-link" href="/api">Fejlesztőknek</a></li>
                <li class="nav-item"><a class="nav-link" href="/informaciok">Információk</a></li>
                {% if isEditor() %}
                <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Szerkesztés<span class="caret"></span></a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="{{ route('editor.commentaries.index') }}">
                            <i class="bi bi-chat-left-text"></i> Kommentárok
                        </a>
                    </div>
                </li>
                {% endif %}
              </ul>
              <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    {% if  not session('anonymous_token') %}
                    {% set currentPath = app.request.pathInfo %}
                    <a class="nav-link" href="/login{% if currentPath != '/login' %}?redirect={{ currentPath|url_encode }}{% endif %}">
                        <i class="bi bi-person bi-large"></i> Belépés
                    </a>
                    {% else %}
                        <a class="nav-link" href="/profile/{{ session('anonymous_token') }}" title="{% if isEditor() %}Szerkesztő{% else %}Felhasználó{% endif %}">
                            {% if isEditor() %}
                                <i class="bi bi-person-gear bi-large" style="color: #28a745;"></i>
                                <span class="badge bg-success ms-1" style="font-size: 0.6em;">Szerk.</span>
                            {% else %}
                                <i class="bi bi-person-check bi-large"></i>
                            {% endif %}
                        </a>
                    {% endif %}
                </li>
