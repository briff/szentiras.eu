{% set externalIcon %}<i class="bi bi-box-arrow-up-right"></i>{% endset %}

<nav class="navbar navbar-light navbar-expand-md" role="navigation">
    <div class="container-fluid">
    <a class="navbar-brand" href="/">Szentírás.eu</a>
